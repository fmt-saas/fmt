{
    "name": "fmt",
    "description": "This package is used for grouping all packages forming FMT SaaS.",
    "version": "1.0",
    "authors": ["Yesbabylon"],
    "license": "AGPL-3",
    "depends_on": [
        "core",
        "communication",
        "documents",
        "finance",
        "hr",
        "identity",
        "purchase",
        "realestate",
        "sale",
        "stats",
        "infra"
    ],
    "requires_bin": {
        "qpdf": {
            "version": ">=10.0",
            "check": "qpdf --version",
            "package": {
               "generic": "qpdf"
            }
        },
        "pdftotext": {
            "version": ">=0.26",
            "check": "pdftotext -v",
            "package": {
                "generic": "poppler-utils",
                "macos": "poppler"
            }
        },
        "ghostscript": {
            "version": ">=10.0",
            "check": "ghostscript --version",
            "package": {
                "generic": "ghostscript"
            }
        }
    },
    "require-dev": {
        "phpstan/phpstan": ">=2.1"
    },
    "config": {
        "ORG_NAME": "FMT SRL",
        "ORG_URL": "https://symbiose.yesbabylon.com",
        "APP_NAME": "FMT",
        "APP_LOGO_URL": "/assets/img/brand/logo.svg"
    },
    "apps": [
        {
            "id": "settings",
            "name": "Settings",
            "description": "Manage and configure global and App-specific options and parameters.",
            "extends": "settings",
            "icon": "settings",
            "color": "#FF5F00",
            "access": {
                "groups": [
                    "admins"
                ]
            },
            "params": {
                "menus": {
                    "left": "settings.left",
                    "top": "settings.top"
                }
            },
            "show_in_apps": true
        },
        "app"
    ]
}
