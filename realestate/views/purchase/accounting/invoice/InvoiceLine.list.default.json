{
    "name": "Invoice Lines",
    "description": "This view is intended for displaying the invoice lines.",
    "operations": {
        "total": {
            "price": {
                "operation": "SUM",
                "usage": "amount/money:2"
            }
        }
    },
    "header": {
        "layout": "inline",
        "actions": {
            "ACTION.CREATE_INLINE": [
                {
                    "view": false
                }
            ]
        }
    },
    "sort": "asc",
    "limit": 100,
    "layout": {
        "items": [
            {
                "type": "field",
                "value": "invoice_id",
                "width": "20%",
                "visible": false
            },
            {
                "id": "item.name",
                "type": "field",
                "value": "name",
                "width": "20%"
            },
            {
                "type": "field",
                "label": "Account",
                "value": "expense_account_id",
                "width": "20%"
            },
            {
                "type": "field",
                "label": "Apport.",
                "value": "apportionment_id",
                "width": "20%"
            },
            {
                "type": "field",
                "label": "Private",
                "value": "is_private_expense",
                "width": "10%"
            },
            {
                "type": "field",
                "label": "tenant",
                "value": "tenant_share",
                "width": "10%"
            },
            {
                "type": "field",
                "label": "owner",
                "value": "owner_share",
                "width": "10%"
            },
            {
                "type": "field",
                "label": "vat",
                "value": "vat_rate",
                "width": "10%"
            },
            {
                "type": "field",
                "value": "price",
                "width": "15%"
            }
        ]
    }
}
