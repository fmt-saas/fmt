{
    "name": "Invoice",
    "description": "An invoice is a legal document issued by a seller to a buyer that relates to a sale, and is part of the accounting system.",
    "header": {
        "actions": {
            "ACTION.SAVE": [
                {
                    "id": "SAVE_AND_EDIT",
                    "view": "form.default"
                },
                {
                    "id": "SAVE_AND_VIEW"
                }
            ]
        }
    },
    "layout": {
        "groups": [
            {
                "sections": [
                    {
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "50%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "status",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "label": "Condominium",
                                                "value": "condo_id",
                                                "width": "50%",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "value": "price",
                                                "width": "50%",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "value": "supplier_identity_id",
                                                "width": "0%",
                                                "visible": false
                                            },
                                            {
                                                "id": "item.description",
                                                "type": "field",
                                                "value": "description",
                                                "width": "66%"
                                            },
                                            {
                                                "id": "item.invoice_number",
                                                "type": "field",
                                                "label": "Invoice Number",
                                                "value": "supplier_invoice_number",
                                                "width": "33%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Reference",
                                                "value": "payment_reference",
                                                "width": "33%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Supplier",
                                                "value": "suppliership_id",
                                                "width": "33%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Bank Account",
                                                "value": "suppliership_bank_account_id",
                                                "width": "33%"
                                            },
                                            {
                                                "id": "item.invoice_type",
                                                "type": "field",
                                                "value": "invoice_type",
                                                "width": "33%"
                                            },
                                            {
                                                "id": "item.emission_date",
                                                "type": "field",
                                                "value": "emission_date",
                                                "width": "33%"
                                            },
                                            {
                                                "id": "item.due_date",
                                                "type": "field",
                                                "value": "due_date",
                                                "width": "33%"
                                            },
                                            {
                                                "id": "item.reversed_invoice_id",
                                                "type": "field",
                                                "value": "reversed_invoice_id",
                                                "width": "33%",
                                                "visible": ["invoice_type", "=", "credit_note"]
                                            }
                                        ]
                                    },
                                    {
                                        "visible": ["document_id", "<>", null],
                                        "width": "50%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "document_link",
                                                "width": "100%",
                                                "widget": {
                                                    "type": "pdf",
                                                    "height": 700
                                                }
                                            }
                                        ]
                                    },
                                    {
                                        "visible": ["document_id", "is", null],
                                        "width": "50%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "document_id",
                                                "width": "100%"
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            }
        ]
    }
}
