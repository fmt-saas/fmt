                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "is_valid",
                                                "width": "100%",
                                                "visible": ["step", "in", ["assembly_validation", "agenda_processing"]]
                                            },
                                            {
                                                "type": "field",
                                                "value": "invalidity_reason",
                                                "width": "100%"
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "section.resolutions",
                        "label": "Resolutions",
                        "rows": [
