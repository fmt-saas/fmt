{
    "name": "Navigation Node",
    "description": "Configure how a navigation node behaves and appears.",
    "layout": {
        "groups": [
            {
                "sections": [
                    {
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "50%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "name",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "node_type",
                                                "width": "16%",
                                                "widget": {
                                                    "readonly": true
                                                }
                                            },
                                            {
                                                "type": "field",
                                                "value": "code",
                                                "width": "33%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "document_id",
                                                "width": "33%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "condo_id",
                                                "width": "33%",
                                                "widget": {
                                                    "header": {
                                                        "actions": {
                                                            "ACTION.CREATE": false
                                                        }
                                                    }
                                                }
                                            },
                                            {
                                                "type": "field",
                                                "value": "node_visibility",
                                                "width": "33%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "parent folder",
                                                "value": "parent_id",
                                                "width": "33%",
                                                "widget": {
                                                    "header": {
                                                        "actions": {
                                                            "ACTION.CREATE": false
                                                        }
                                                    }
                                                }
                                            }
                                        ]
                                    },
                                    {
                                        "width": "50%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "document_link",
                                                "width": "100%",
                                                "widget": {
                                                    "type": "pdf",
                                                    "height": "720"
                                                }
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            },
            {
                "sections": [
                    {
                        "visible": [
                            [
                                "state",
