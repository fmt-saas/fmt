{
    "name": "Mailboxes",
    "header": {
        "actions": {
            "ACTION.CREATE":  false
        }
    },
    "actions": [
        {
            "id": "action.add_mailbox",
            "label": "Add mailbox",
            "description": "Add a new mailbox for emails fetching automation.",
            "component": {
                "name": "communicationAddMailbox"
            }
        },
        {
            "id": "action.connect",
            "inline": true,
            "label": "Auth",
            "icon": "login",
            "description": "Provide authentication info for connection.",
            "component": {
                "name": "communicationAddMailbox",
                "data": {
                    "mailbox_id": "object.id"
                }
            },
            "visible": ["pending", "=", "object.status"]
        },
        {
            "id": "action.fetch_emails",
            "inline": true,
            "label": "Download",
            "icon": "sync",
            "description": "Fetch latest emails and import attachments.",
            "controller": "communication_email_Mailbox_fetch",
            "params": {
                "id": "object.id"
            },
            "visible": ["validated", "=", "object.status"]
        }
    ],
    "layout": {
        "items": [
            {
                "type": "field",
                "value": "email",
                "width": "33%"
            },
            {
                "type": "field",
                "value": "imap_server",
                "width": "20%"
            },
            {
                "type": "field",
                "value": "imap_port",
                "width": "15%"
            },
            {
                "type": "field",
                "value": "auth_type",
                "width": "15%"
            },
            {
                "type": "field",
                "value": "status",
                "width": "15%"
            }
        ]
    }
}