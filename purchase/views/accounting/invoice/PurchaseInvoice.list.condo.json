{
    "name": "Invoice",
    "description": "An invoice is a legal document issued by a seller to a buyer that relates to a sale, and is part of the accounting system.",
    "controller": "purchase_accounting_invoice_collect",
    "header": {
        "actions": {
            "ACTION.CREATE": [
                {
                    "view": "form.create"
                }
            ]
        }
    },
    "routes": [
        {
            "id": "item.import",
            "label": "Import an Invoice",
            "description": "",
            "icon": "receipt_long",
            "context": {
                "entity": "documents\\processing\\DocumentProcess",
                "view": "form.import",
                "purpose": "create"
            }
        }
    ],
    "extends": {
        "entity": "finance\\accounting\\invoice\\Invoice",
        "view": "list.default"
    },
    "layout": {
        "update": {
            "item.name": {
                "after": [
                    {
                        "type": "field",
                        "label": "Supplier",
                        "value": "supplier_id",
                        "width": "20%",
                        "sortable": true
                    }
                ]
            },
            "item.emission.date": {
                "after": [
                    {
                        "type": "field",
                        "label": "Supplier Ref",
                        "value": "supplier_invoice_number",
                        "width": "20%"
                    },
                    {
                        "type": "field",
                        "value": "description",
                        "width": "20%"
                    }
                ]
            }
        }
    }
}