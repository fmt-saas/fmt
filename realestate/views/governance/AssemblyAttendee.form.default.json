{
    "name": "Assembly Attendee",
    "description": "Represents an attendee at a condominium assembly, which can be an owner or a proxy (not necessarily an owner), or an owner with proxy from other owners.",
    "header": {
        "actions": {
            "ACTION.EDIT": false
        }
    },
    "actions": [
        {
            "id": "action.promote_president",
            "label": "Promote as President",
            "description": "Promote the attendee as president of the Assembly.",
            "controller": "core_model_do",
            "params": {
                "entity": "realestate\\governance\\AssemblyAttendee",
                "action": "promote_president"
            },
            "visible": ["attendee_role", "<>", "president"]
        },
        {
            "id": "action.demote_president",
            "label": "Demote presidency",
            "description": "Remove the presidency role on the attendee.",
            "controller": "core_model_do",
            "params": {
                "entity": "realestate\\governance\\AssemblyAttendee",
                "action": "demote_president"
            },
            "visible": ["attendee_role", "=", "president"]
        },
        {
            "id": "action.validate",
            "label": "Validate",
            "description": "Validate the attendee.",
            "controller": "core_model_transition",
            "params": {
                "entity": "realestate\\governance\\AssemblyAttendee",
                "transition": "validate"
            },
            "visible": ["status", "=", "pending"]
        },
        {
            "id": "action.leave_assembly",
            "label": "Record departure",
            "description": "Mark the attendee as having left the Assembly.",
            "controller": "core_model_do",
            "params": {
                "entity": "realestate\\governance\\AssemblyAttendee",
                "action": "leave_assembly"
            },
            "visible": ["has_early_departure", "=", false]
        },
        {
            "id": "action.delete",
            "label": "Delete attendee",
            "description": "Delete an attendee.",
            "controller": "realestate_governance_AssemblyAttendee_delete"
        }
    ],
    "layout": {
        "groups": [
            {
                "sections": [
                    {
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "condo_id",
                                                "width": "100%",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "value": "assembly_id",
                                                "width": "100%",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "value": "register_document_id",
                                                "width": "100%",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "value": "has_early_departure",
                                                "width": "100%",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "value": "identity_id",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "has_mandate",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "attendee_role",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Register Signature",
                                                "value": "register_document_signature_id",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Minutes Signature",
                                                "value": "minutes_document_signature_id",
                                                "width": "100%"
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            },
            {
                "visible": [["state", "=", "instance"], ["has_mandate", "=", true]],
                "sections": [
                    {
                        "id":"section.proxies",
                        "label": "Mandates",
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "assembly_mandates_ids",
                                                "width": "100%"
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id":"section.owners",
                        "label": "Owners",
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "assembly_representations_ids",
                                                "width": "100%"
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            }
        ]
    }
}
