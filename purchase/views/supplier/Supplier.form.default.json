{
    "name": "Supplier",
    "description": "Supplier default form.",
    "extends": {
        "entity": "identity\\Identity",
        "view": "form.default"
    },
    "actions": [
        {
            "id": "action.sync",
            "label": "Sync from Identity",
            "controller": "core_model_do",
            "params": {
                "entity": "purchase\\supplier\\Supplier",
                "action": "sync_from_identity",
                "ids": []
            },
            "visible": ["admins", "in", "user.groups"],
            "confirm": false
        }
    ],
    "layout": {
        "remove": ["field.signature", "field.profile_image_document_id"],
        "update": {
            "column.signature": {
                "prepend": [
                    {
                        "type": "field",
                        "label": "Supplier types",
                        "value": "supplier_types_ids",
                        "width": "100%",
                        "widget": {
                            "header": {
                                "layout": "inline"
                            }
                        }
                    }
                ]
            },
            "item.bank_accounts_ids": {
                "attributes": {
                    "widget": {
                        "header": {
                            "actions": {

                            },
                            "selection": false
                        }
                    }
                }
            }
        }
    }
}