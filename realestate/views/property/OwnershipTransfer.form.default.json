{
    "name": "Ownership Transfer",
    "description": "Transfer of Ownership for one or more property lots.",
    "header": {
        "actions": {
            "ACTION.SAVE": [
                {
                    "id": "SAVE_AND_VIEW"
                }
            ]
        }
    },
    "actions": [
        {
            "id": "action.open",
            "label": "Open",
            "description": "Validate data and start the transfer process.",
            "controller": "core_model_transition",
            "visible": [ ["status", "=", "pending"] ],
            "params": {
                "entity": "realestate\\property\\OwnershipTransfer",
                "transition": "open",
                "ids": []
            }
        },
        {
            "id": "action.confirm",
            "label": "Confirm",
            "description": "Validate data and start the transfer process.",
            "controller": "core_model_transition",
            "visible": [ ["status", "in", ["open", "seller_documents_sent"]] ],
            "params": {
                "entity": "realestate\\property\\OwnershipTransfer",
                "transition": "confirm",
                "ids": []
            }
        },
        {
            "id": "action.settle",
            "label": "Settle",
            "description": "Validate data and start the transfer process.",
            "controller": "core_model_transition",
            "visible": [ ["status", "in", ["confirmed", "financial_statement_sent"]] ],
            "params": {
                "entity": "realestate\\property\\OwnershipTransfer",
                "transition": "settle",
                "ids": []
            }
        },
        {
            "id": "action.generate_adjustments",
            "label":     "Generate Adjustments",
            "description": "Generate accounting accounts.",
            "controller": "core_model_do",
            "visible": ["status", "in", ["settled"]],
            "params": {
                "entity": "realestate\\property\\OwnershipTransfer",
                "action": "generate_adjustments",
                "ids": []
            },
            "confirm": false
        },
        {
            "id": "action.perform_transfer",
            "label": "Perform Transfer",
            "description": "Generate accounting accounts.",
            "controller": "core_model_do",
            "visible": ["status", "in", ["settled"]],
            "params": {
                "entity": "realestate\\property\\OwnershipTransfer",
                "action": "perform_transfer",
                "ids": []
            },
            "confirm": false
        }
    ],
    "routes": [
        {
            "id": "route.print.pdf",
            "label": "Print mail",
            "description": "Displays all lines but without group.",
            "icon": "print",
            "route": "/?get=realestate_property_OwnershipTransfer_render-pdf&id=object.id",
            "target": "_blank",
            "absolute": true,
            "visible": ["status", "<>", "pending"]
        }
    ],
    "layout": {
        "groups": [
            {
                "sections": [
                    {
                        "id": "section.main",
                        "label": "Owner & Lots",
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "50%",
                                        "items": [
                                            {
                                                "type": "label",
                                                "value": "Notary Request",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Date of the notary request",
                                                "value": "request_date",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "label",
                                                "value": "Condominium & Owner",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "condo_id",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Current Owner",
                                                "value": "old_ownership_id",
                                                "width": "50%",
                                                "visible": ["condo_id", "<>", null],
                                                "widget": {
                                                    "header": {
                                                        "actions": {
                                                            "ACTION.CREATE": false
                                                        }
                                                    }
                                                }
                                            },
                                            {
                                                "type": "field",
                                                "value": "property_lot_id",
                                                "width": "50%",
                                                "visible": [["condo_id", "<>", null], ["status", "=", "pending"]],
                                                "widget": {
                                                    "header": {
                                                        "actions": {
                                                            "ACTION.CREATE": false
                                                        }
                                                    }
                                                }
                                            }
                                        ]
                                    },
                                    {
                                        "width": "50%",
                                        "visible": [["condo_id", "<>", null], ["old_ownership_id", "<>", null]],
                                        "items": [
                                            {
                                                "type": "label",
                                                "value": "Selected Property Lots",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "property_lots_ids",
                                                "width": "100%",
                                                "widget": {
                                                    "header": {
                                                        "layout": "inline",
                                                        "actions": {
                                                            "ACTION.SELECT": true,
                                                            "ACTION.CREATE": false
                                                        }
                                                    }
                                                }
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "section.information_documents",
                        "label": "Information (3.94 §1)",
                        "visible": [["condo_id", "<>", null], ["old_ownership_id", "<>", null], ["status", "in", ["open", "seller_documents_sent", "confirmed", "financial_statement_sent", "settled"]]],
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "50%",
                                        "items": [
                                            {
                                                "type": "label",
                                                "value": "Required Information",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "has_judiciary_procedures",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "judiciary_procedures_description",
                                                "width": "100%"
                                            }
                                        ]
                                    },
                                    {
                                        "width": "50%",
                                        "items": [
                                            {
                                                "type": "label",
                                                "value": "Funds balances",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Condominium funds balances",
                                                "value": "fund_balances_ids",
                                                "width": "100%",
                                                "widget": {
                                                    "header": {
                                                        "layout": "inline",
                                                        "actions": {
                                                            "ACTION.CREATE": false
                                                        }
                                                    }
                                                }
                                            },
                                            {
                                                "type": "label",
                                                "value": "Owner arrears",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Owner arrears",
                                                "value": "arrear_fundings_ids",
                                                "width": "100%",
                                                "widget": {
                                                    "header": {
                                                        "layout": "inline",
                                                        "actions": {
                                                            "ACTION.CREATE": false
                                                        }
                                                    },
                                                    "view": "list.arrears"
                                                }
                                            },
                                            {
                                                "type": "label",
                                                "value": "Transfer file fees",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "transfer_fees_ids",
                                                "width": "100%"
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "section.information_statements",
                        "label": "Information (3.94 §2)",
                        "visible": [["condo_id", "<>", null], ["old_ownership_id", "<>", null], ["status", "in", ["confirmed", "financial_statement_sent", "settled"]]],
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "50%",
                                        "items": [
                                            {
                                                "type": "label",
                                                "value": "Notary confirmation",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Date of the notary confirmation",
                                                "value": "confirmation_date",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "has_intervention_record",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "has_fuel_tank",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "fuel_tank_capacity",
                                                "width": "50%"
                                            }
                                        ]
                                    },
                                    {
                                        "width": "50%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "label": "Fund requests",
                                                "value": "fund_requests_ids",
                                                "width": "100%",
                                                "widget": {
                                                    "header": {
                                                        "layout": "inline",
                                                        "actions": {
                                                            "ACTION.CREATE": false
                                                        }
                                                    }
                                                }
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "section.information_settlement",
                        "label": "Information (3.94 §3)",
                        "visible": [["condo_id", "<>", null], ["old_ownership_id", "<>", null], ["status", "=", "settled"]],
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "50%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "transfer_date"
                                            },
                                            {
                                                "type": "field",
                                                "label": "New Owner",
                                                "value": "new_ownership_id",
                                                "width": "100%",
                                                "widget": {
                                                    "header": {
                                                        "actions": {
                                                            "ACTION.CREATE": [
                                                                {
                                                                    "view": "form.transfer_create"
                                                                }
                                                            ]
                                                        }
                                                    }
                                                }
                                            }
                                        ]
                                    },
                                    {
                                        "width": "16%",
                                        "items": []
                                    },
                                    {
                                        "width": "33%",
                                        "items": []
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "section.transfer_details",
                        "label": "Transfer",
                        "visible": [["condo_id", "<>", null], ["old_ownership_id", "<>", null], ["status", "=", "settled"]],
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "adjustments_ids",
                                                "widget": {
                                                    "header": {
                                                        "layout": "inline",
                                                        "actions": {
                                                            "ACTION.CREATE": false
                                                        }
                                                    },
                                                    "view": "list.transfer"
                                                }
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            }
        ]
    }
}
