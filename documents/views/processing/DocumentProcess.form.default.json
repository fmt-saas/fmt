{
    "name": "Document Processing",
    "description": "Document import.",
    "header": {
        "actions": {
            "ACTION.SAVE": [
                {
                    "id": "SAVE_AND_VIEW",
                    "view": "form.default"
                }
            ]
        }
    },
    "actions": [
        {
            "id": "action.perform_analysis",
            "label": "Analyze",
            "description": "Attempt to analyze the content of the document.",
            "controller": "core_model_do",
            "params": {
                "entity": "documents\\processing\\DocumentProcess",
                "action": "perform_analysis"
            },
            "visible": [ ["state", "=", "instance"], ["status", "=", "created"], ["has_analysis", "=", false] ]
        },
        {
            "id": "action.complete",
            "label": "Complete",
            "description": "Mark the document as completed.",
            "controller": "core_model_transition",
            "visible": [ ["status", "=", "created"] ],
            "params": {
                "entity": "documents\\processing\\DocumentProcess",
                "transition": "complete",
                "ids": []
            }
        },
        {
            "id": "action.validate",
            "label": "Validate",
            "description": "Mark the document as validated.",
            "controller": "core_model_transition",
            "visible": [ ["status", "=", "completed"] ],
            "params": {
                "entity": "documents\\processing\\DocumentProcess",
                "transition": "validate",
                "ids": []
            }
        },
        {
            "id": "action.record",
            "label": "Resolve",
            "description": "Create related entities as proforma.",
            "controller": "core_model_transition",
            "visible": [ ["status", "=", "validated"] ],
            "params": {
                "entity": "documents\\processing\\DocumentProcess",
                "transition": "record",
                "ids": []
            }
        },
        {
            "id": "action.confirm",
            "label": "Confirm",
            "description": "Mark the document as confirmed.",
            "controller": "core_model_transition",
            "visible": [ ["status", "=", "recorded"] ],
            "params": {
                "entity": "documents\\processing\\DocumentProcess",
                "transition": "confirm",
                "ids": []
            }
        },
        {
            "id": "action.integrate",
            "label": "Integrate",
            "description": "Integrate the document to accounting.",
            "controller": "core_model_transition",
            "visible": [ ["status", "=", "confirmed"] ],
            "params": {
                "entity": "documents\\processing\\DocumentProcess",
                "transition": "integrate",
                "ids": []
            }
        },
        {
            "id": "action.delete",
            "label": "Delete",
            "description": "Delete the import and the related document.",
            "controller": "core_model_delete",
            "params": {
                "entity": "documents\\processing\\DocumentProcess",
                "permanent": true,
                "ids": []
            },
            "confirm": true,
            "visible": [ ["state", "=", "instance"], ["status", "=", "created"] ]
        }
    ],
    "layout": {
        "groups": [
            {
                "sections": [
                    {
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "50%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "label": "Document",
                                                "value": "document_id",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Condominium",
                                                "value": "condo_id",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Supplier",
                                                "value": "supplier_id",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Doc Type",
                                                "value": "document_type_code",
                                                "width": "50%",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "label": "Invoice",
                                                "value": "document_invoice_id",
                                                "width": "50%",
                                                "widget": {
                                                    "description": "il faudrait empêcher la sélection, et permettre uniquement la création"
                                                }
                                            },
                                            {
                                                "type": "field",
                                                "label": "Bank Statement",
                                                "value": "document_bank_statement_id",
                                                "width": "50%",
                                                "widget": {
                                                    "readonly": true
                                                }
                                            },
                                            {
                                                "type": "field",
                                                "label": "Doc Type",
                                                "value": "document_type_id",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Doc Sub Type",
                                                "value": "document_subtype_id",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Report",
                                                "value": "report_html",
                                                "width": "100%",
                                                "widget": {
                                                    "height": 440
                                                }
                                            }
                                        ]
                                    },
                                    {
                                        "width": "50%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "document_link",
                                                "width": "100%",
                                                "visible": ["document_type_code", "in", ["invoice", "credit_note"]],
                                                "widget": {
                                                    "type": "pdf",
                                                    "height": 700
                                                }
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            }
        ]
    }
}
