{
    "name": "Organisation",
    "description": "Form holding basic information about an Organisation.",
    "routes": [
        {
            "id": "item.ownerships",
            "label": "Owners",
            "description": "",
            "icon": "group",
            "context": {
                "entity": "realestate\\ownership\\Ownership",
                "view": "list.default",
                "domain": ["condo_id", "=", "object.id"]
            }
        },
        {
            "id": "item.property_lots",
            "label": "Property Lots",
            "description": "",
            "icon": "apartment",
            "context": {
                "entity": "realestate\\property\\PropertyLot",
                "view": "list.default",
                "domain": ["condo_id", "=", "object.id"]
            }
        },
        {
            "id": "item.role_assignments",
            "label": "Roles Assignments",
            "description": "",
            "icon": "library_books",
            "context": {
                "entity": "hr\\role\\RoleAssignment",
                "view": "list.default",
                "domain": ["condo_id", "=", "object.id"]
            }
        },
        {
            "id": "item.statutory_quotas",
            "label": "Statutory Quotas",
            "description": "",
            "icon": "pie_chart",
            "context": {
                "entity": "realestate\\property\\Apportionment",
                "view": "list.default",
                "domain": [["condo_id", "=", "object.id"], ["is_statutory", "=", true]]
            }
        },
        {
            "id": "item.apportionment_keys",
            "label": "Apportionment keys",
            "description": "",
            "icon": "account_tree",
            "context": {
                "entity": "realestate\\property\\Apportionment",
                "view": "list.default",
                "domain": [["condo_id", "=", "object.id"], ["is_statutory", "=", false]]
            }
        },
        {
            "id": "item.fiscal_year",
            "label": "Fiscal years",
            "description": "",
            "icon": "date_range",
            "context": {
                "entity": "finance\\accounting\\FiscalYear",
                "view": "list.condo",
                "domain": [["condo_id", "=", "object.id"]]
            }
        },
        {
            "id": "item.accounting_entries",
            "label": "Accounting entries",
            "description": "",
            "icon": "edit_note",
            "context": {
                "entity": "finance\\accounting\\AccountingEntry",
                "view": "list.condo",
                "domain": [["condo_id", "=", "object.id"]]
            }
        },
        {
            "id": "item.current_balance",
            "label": "Current Balance",
            "description": "",
            "icon": "balance",
            "context": {
                "entity": "finance\\accounting\\CurrentBalanceLine",
                "view": "list.condo",
                "domain": [["condo_id", "=", "object.id"]]
            }
        },
        {
            "id": "item.accounts_chart",
            "label": "Chart of Accounts",
            "description": "",
            "icon": "menu_book",
            "context": {
                "entity": "finance\\accounting\\AccountChart",
                "view": "form.condo",
                "domain": [["id", "=", "object.account_chart_id"], ["condo_id", "=", "object.id"]]
            }
        }
    ],
    "actions": [
        {
            "id": "action.generate_sequences",
            "label": "Generate sequences",
            "description": "Generate mandatory sequences.",
            "controller": "core_model_perform",
            "params": {
                "entity": "realestate\\property\\Condominium",
                "action": "generate_sequences",
                "ids": []
            },
            "confirm": false
        },
        {
            "id": "action.open_fiscal_year",
            "label": "Open fiscal Year",
            "description": "Open the fiscal year. This action cannot be undone.",
            "controller": "core_model_perform",
            "params": {
                "entity": "realestate\\property\\Condominium",
                "action": "open_fiscal_year",
                "ids": []
            },
            "confirm": true
        },
        {
            "id": "action.create_fiscal_year",
            "label": "Create draft fiscal Year",
            "description": "Create a new fiscal year draft. This will overwrite any existing fiscal year draft.",
            "controller": "core_model_perform",
            "params": {
                "entity": "realestate\\property\\Condominium",
                "action": "create_draft_fiscal_year",
                "ids": []
            },
            "confirm": true
        }
    ],
