{
    "name": "Documents Processing",
    "description": "List of documents processing in progress.",
    "header": {
        "actions": {
            "ACTION.CREATE" : false
        }
    },
    "routes": [
        {
            "id": "route.document_process",
            "label": "Document Process",
            "inline": true,
            "description": "",
            "icon": "visibility",
            "context": {
                "entity": "documents\\processing\\DocumentProcess",
                "view": "form.default",
                "domain": ["id", "=", "object.id"]
            },
            "visible": [
                [false, "=", "object.has_target_object"]
            ]
        },
        {
            "id": "route.purchase_invoice",
            "label": "Invoice",
            "inline": true,
            "description": "",
            "icon": "visibility",
            "context": {
                "entity": "realestate\\purchase\\accounting\\invoice\\PurchaseInvoice",
                "view": "form.default",
                "domain": ["id", "=", "object.document_invoice_id"]
            },
            "visible": [
                [true, "=", "object.has_target_object"],
                ["invoice", "=", "object.document_type_code"]
            ]
        },
        {
            "id": "route.bank_statement",
            "label": "Bank Statement",
            "inline": true,
            "description": "",
            "icon": "visibility",
            "context": {
                "entity": "finance\\bank\\BankStatement",
                "view": "form.default",
                "domain": ["id", "=", "object.document_bank_statement_id"]
            },
            "visible": [
                [true, "=", "object.has_target_object"],
                ["bank_statement", "=", "object.document_type_code"]
            ]
        }
    ],
    "layout": {
        "items": [
            {
                "type": "field",
                "value": "document_invoice_id",
                "width": "0%",
                "visible": false
            },
            {
                "type": "field",
                "value": "document_bank_statement_id",
                "width": "0%",
                "visible": false
            },
            {
                "type": "field",
                "value": "document_type_code",
                "width": "0%",
                "visible": false
            },
            {
                "type": "field",
                "value": "has_target_object",
                "width": "0%",
                "visible": false
            },
            {
                "type": "field",
                "value": "name",
                "width": "25%",
                "sortable": true
            },
            {
                "type": "field",
                "label": "Created",
                "value": "created",
                "width": "10%",
                "readonly": true,
                "widget": {
                    "usage": "date"
                }
            },
            {
                "type": "field",
                "value": "description",
                "width": "33%",
                "readonly": true
            },
            {
                "type": "field",
                "value": "assigned_employee_id",
                "width": "25%"
            },
            {
                "type": "field",
                "value": "document_id",
                "width": "25%",
                "readonly": true
            },
            {
                "type": "field",
                "value": "status",
                "width": "10%",
                "readonly": true,
                "widget": {
                    "text_weight": "500",
                    "background_color": "#dcfce7",
                    "text_align": "center",
                    "border_radius": "5px",
                    "padding": "4px"
                }
            }
        ]
    }
}