{
    "name": "Assembly Item",
    "actions": [
        {
            "id": "action.open",
            "label": "Open",
            "description": "Open the assembly point.",
            "controller": "core_model_transition",
            "params": {
                "entity": "realestate\\governance\\AssemblyItem",
                "transition": "open"
            },
            "visible": [["assembly_status", "=", "in_progress"], ["status", "=", "pending"]]
        },
        {
            "id": "action.close",
            "label": "Close",
            "description": "Close the assembly point. No more vote will be allowed. This cannot be undone.",
            "controller": "core_model_transition",
            "params": {
                "entity": "realestate\\governance\\AssemblyItem",
                "transition": "close"
            },
            "visible": ["status", "=", "open"]
        },
        {
            "id": "action.cast_vote",
            "label": "Cast a Vote",
            "icon": "how_to_vote",
            "description": "Cast a vote.",
            "component": {
                "name": "assemblyVoteCast",
                "data": {
                    "assembly_id": "object.assembly_id",
                    "assembly_item_id": "object.id"
                }
            },
            "visible": [ [true, "=", "object.has_vote_required"], ["open", "=", "object.status"] ]
        }
    ],
    "routes": [
        {
            "id": "route.add_attachment",
            "label": "Add attachment",
            "description": "",
            "icon": "file_upload",
            "context": {
                "entity": "documents\\Document",
                "view": "form.upload",
                "purpose": "create",
                "mode": "edit",
                "domain": [ ["condo_id", "=", "object.condo_id"], ["assembly_id", "=", "object.assembly_id"], ["assembly_item_id", "=", "object.id"] ]
            }
        }
    ],
    "layout": {
        "interactions": {
            "autofocus": false
        },
        "groups": [
            {
                "sections": [
                    {
                        "id": "section.details",
                        "label": "Details",
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "condo_id",
                                                "width": "50%",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "value": "assembly_id",
                                                "width": "50%",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "value": "assembly_status",
                                                "width": "50%",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "value": "name",
                                                "width": "75%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "code",
                                                "width": "25%"
                                            }
                                        ]
                                    }
                                ]
                            },
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "is_group",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "has_parent_group",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "parent_group_id",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "has_vote_required",
                                                "width": "25%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "has_choices",
                                                "width": "25%",
                                                "visible": false
                                            },
                                            {
                                                "type": "label",
                                                "value": "",
                                                "width": "25%",
                                                "visible": ["has_vote_required", "=", false]
                                            },
                                            {
                                                "type": "field",
                                                "value": "majority",
                                                "width": "25%",
                                                "visible": ["has_choices", "=", false]
                                            },
                                            {
                                                "id": "label.choices_notice",
                                                "type": "label",
                                                "value": "Please provide choices.",
                                                "width": "25%",
                                                "visible": ["has_choices", "=", true]
                                            },
                                            {
                                                "type": "field",
                                                "value": "apportionment_id",
                                                "width": "25%"
                                            }
                                        ]
                                    },
                                    {
                                        "width": "33%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "count_represented_shares",
                                                "width": "100%"
                                            }
                                        ]
                                    }
                                ]
                            },
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "description_call",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "description_minutes",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "description_ballot",
                                                "width": "100%"
                                            }
                                        ]
                                    }
                                ]
                            },
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "children_items_ids",
                                                "width": "100%",
                                                "widget": {
                                                    "view": "list.item"
                                                }
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "section.votes",
                        "label": "Votes",
                        "visible": [["has_vote_required", "=", true], ["status", "<>", "pending"]],
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "vote_result",
                                                "width": "50%"
                                            }
                                        ]
                                    }
                                ]
                            },
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "assembly_votes_ids",
                                                "width": "100%",
                                                "widget": {
                                                    "view": "list.item",
                                                    "header": {
                                                        "actions": {
                                                            "ACTION.SELECT": false,
                                                            "ACTION.CREATE": false
                                                        }
                                                    }
                                                }
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "section.documents",
                        "label": "Documents",
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "documents_ids",
                                                "width": "100%",
                                                "widget": {
                                                    "view": "list.assembly",
                                                    "header": {
                                                        "layout": "inline",
                                                        "actions": {
                                                            "ACTION.SELECT" : false,
                                                            "ACTION.ADD" : false
                                                        }
                                                    }
                                                }
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "section.choices",
                        "label": "Choices",
                        "visible": [["has_vote_required", "=", true], ["has_choices", "=", true]],
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "assembly_item_choices_ids",
                                                "width": "100%"
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            }
        ]
    }
}