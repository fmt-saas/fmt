{
    "name": "Messages list",
    "description": "Listing of pending messages.",
    "domain": [
        [
            ["group_id", "in", "user.condos_ids"]
        ],
        [
            ["user_id", "=", "user.id"]
        ]
    ],
    "header": {
        "layout": "inline",
        "actions": false,
        "selection": {
            "default" : false,
            "actions" : [
                {
                    "id": "header.selection.actions.bulk_dismiss",
                    "label": "Revérifier",
                    "icon": "replay",
                    "controller": "core_alert_bulk-dismiss"
                }
            ]
        }
    },
    "order": "created",
    "sort": "asc",
    "layout": {
        "items": [
            {
                "type": "field",
                "value": "object_link",
                "width": "25%"
            },
            {
                "type": "field",
                "value": "created",
                "width": "10%",
                "widget": {
                    "sortable": true,
                    "usage": "datetime/short"
                }
            },
            {
                "type": "field",
                "value": "label",
                "width": "15%"
            },
            {
                "type": "field",
                "value": "alert",
                "width": "15%",
                "widget": {
                    "type": "string",
                    "usage": "icon"
                }
            },
            {
                "type": "field",
                "value": "description",
                "label": "Name",
                "width": "50%"
            },
            {
                "type": "field",
                "value": "center_office_id",
                "visible": false
            },
            {
                "type": "field",
                "value": "object_id",
                "visible": false
            }

        ]
    }
}
