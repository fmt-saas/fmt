{
    "name": "Invoice Lines",
    "description": "This view is intended for displaying the invoice lines.",
    "operations": {
        "total": {
            "price": {
                "operation": "SUM",
                "usage": "amount/money:2"
            }
        }
    },
    "header": {
        "layout": "inline",
        "actions": {
            "ACTION.CREATE": false,
            "ACTION.CREATE_INLINE": false
        }
    },
    "routes": [
        {
            "id": "item.import",
            "label": "Import an Invoice",
            "description": "",
            "icon": "receipt_long",
            "context": {
                "entity": "documents\\processing\\DocumentProcess",
                "view": "form.import",
                "purpose": "create"
            }
        }
    ],
    "sort": "asc",
    "limit": 100,
    "layout": {
        "items": [
            {
                "type": "field",
                "value": "condo_id",
                "width": "20%",
                "visible": false
            },
            {
                "type": "field",
                "value": "invoice_id",
                "width": "20%",
                "visible": false
            },
            {
                "type": "field",
                "value": "qty",
                "width": "20%",
                "visible": false
            },
            {
                "type": "field",
                "value": "unit_price",
                "width": "20%",
                "visible": false
            },
            {
                "type": "field",
                "label": "Account",
                "value": "expense_account_id",
                "width": "20%"
            },
            {
                "type": "field",
                "label": "Apport.",
                "value": "apportionment_id",
                "width": "20%"
            },
            {
                "type": "field",
                "label": "Private",
                "value": "is_private_expense",
                "width": "10%"
            },
            {
                "type": "field",
                "label": "tenant",
                "value": "tenant_share",
                "width": "10%"
            },
            {
                "type": "field",
                "label": "owner",
                "value": "owner_share",
                "width": "10%"
            },
            {
                "type": "field",
                "label": "vat",
                "value": "vat_rate",
                "width": "10%"
            },
            {
                "type": "field",
                "value": "price",
                "width": "15%"
            }
        ]
    }
}
