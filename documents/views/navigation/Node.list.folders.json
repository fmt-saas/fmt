{
    "name": "Folders",
    "description": "List of root folders, by Condominium.",
    "actions": [
        {
            "id": "action.download",
            "inline": true,
            "label": "Download",
            "icon": "download",
            "description": "Download the document.",
            "controller": "documents_navigation_Node_download",
            "visible": ["node_type", "=", "document"]
        }
    ],
    "order": "name",
    "sort": "asc",
    "layout": {
        "items": [
            {
                "type": "field",
                "value": "parent_id",
                "width": "0%",
                "visible": false
            },
            {
                "type": "field",
                "label": "type",
                "value": "node_type",
                "width": "10%",
                "widget": {
                    "type": "string",
                    "usage": "icon"
                }
            },
            {
                "type": "field",
                "value": "name",
                "width": "14%"
            },
            {
                "type": "field",
                "label": "Items",
                "value": "nodes_count",
                "width": "10%",
                "widget": {
                    "align": "center",
                    "margin": "auto",
                    "styles": {
                        "text_align": "center",
                        "text_width": "40px",
                        "text_weight": "bold",
                        "text_color": "white",
                        "background_color": "#3f51b5",
                        "border_radius": "40px"
                    }
                },
                "visible": ["nodes_count", ">", 0]
            },
            {
                "type": "field",
                "label": "Condominium",
                "value": "condo_id",
                "width": "20%"
            },
            {
                "type": "field",
                "value": "description",
                "width": "25%"
            }
        ]
    }
}