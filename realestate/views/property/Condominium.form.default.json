{
    "name": "Organisation",
    "description": "Form holding basic information about an Organisation.",
    "routes": [
        {
            "id": "item.ownerships",
            "label": "Owners",
            "description": "",
            "icon": "group",
            "context": {
                "entity": "realestate\\ownership\\Ownership",
                "view": "list.default",
                "domain": ["condo_id", "=", "object.id"]
            }
        },
        {
            "id": "item.property_lots",
            "label": "Property Lots",
            "description": "",
            "icon": "apartment",
            "context": {
                "entity": "realestate\\property\\PropertyLot",
                "view": "list.default",
                "domain": ["condo_id", "=", "object.id"]
            }
        },
        {
            "id": "item.accounting",
            "label": "Accounting",
            "description": "",
            "icon": "edit_note",
            "context": {
                "entity": "realestate\\property\\Condominium",
                "view": "form.accounting",
                "domain": [["id", "=", "object.id"]]
            }
        },
        {
            "id": "documents",
            "type": "entry",
            "label": "Documents",
            "icon": "folder",
            "description": "",
            "context": {
                "entity": "documents\\navigation\\Node",
                "view": "list.folders",
                "domain": [["node_type", "=", "folder"], ["parent_id", "=", null], ["condo_id", "=", "object.id"]]
            }
        },
        {
            "id": "bank_accounts",
            "type": "entry",
            "label": "Bank Accounts",
            "icon": "account_balance",
            "description": "",
            "context": {
                "entity": "realestate\\property\\Condominium",
                "view": "form.banking",
                "domain": [["id", "=", "object.id"]]
            }
        },
        {
            "id": "suppliers",
            "type": "entry",
            "label": "Suppliers",
            "icon": "storefront",
            "description": "",
            "context": {
                "entity": "purchase\\supplier\\Suppliership",
                "view": "list.default",
                "domain": [["condo_id", "=", "object.id"]]
            }
        },
        {
            "id": "item.governance",
            "label": "Governance",
            "description": "",
            "icon": "how_to_vote",
            "context": {
                "entity": "realestate\\property\\Condominium",
                "view": "form.governance",
                "domain": [["id", "=", "object.id"]]
            }
        },
        {
            "id": "item.admin",
            "label": "Config",
            "description": "",
            "icon": "settings",
            "context": {
                "entity": "realestate\\property\\Condominium",
                "view": "form.admin",
                "domain": [["id", "=", "object.id"]]
            }
        }
    ],
    "actions": [
        {
            "id": "action.validate",
            "label": "Validate",
            "icon": "play_arrow",
            "description": "Generate mandatory configuration.",
            "controller": "core_model_transition",
            "visible": ["status", "=", "pending"],
            "params": {
                "entity": "realestate\\property\\Condominium",
                "transition": "validate",
                "ids": []
            },
            "confirm": false
        }
    ],
    "layout": {
        "groups": [
            {
                "sections": [
                    {
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "50%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "legal_name",
                                                "width": "100%",
                                                "widget": {
                                                    "header": false
                                                }
                                            }
                                        ]
                                    },
                                    {
                                        "width": "25%",
                                        "items": []
                                    },
                                    {
                                        "width": "25%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "label": "Language",
                                                "value": "lang_id",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "type_id",
                                                "width": "100%",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "value": "type",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "value": "has_parent",
                                                "visible": false
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            },
            {
                "sections": [
                    {
                        "label": "Owners",
                        "id": "section.owners",
                        "rows": [
                            {

                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "ownerships_ids",
                                                "width": "100%"
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            }
        ]
    }
