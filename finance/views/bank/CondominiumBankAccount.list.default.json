{
    "name": "Condominium Bank Account",
    "description": "Condominium bank account list.",
    "extends": {
        "entity": "finance\\bank\\BankAccount",
        "view": "list.default"
    },
    "routes": [
    ],
    "layout": {
        "update": {
            "item.is_primary": {
                "after": [
                    {
                        "type": "field",
                        "label": "Balance",
                        "value": "current_balance",
                        "width": "10%"
                    },
                    {
                        "type": "field",
                        "label": "Estimated",
                        "value": "available_balance",
                        "width": "10%"
                    },
                    {
                        "type": "field",
                        "value": "condo_id",
                        "width": "10%",
                        "visible": false
                    }
                ]
            }
        }
    }
}