                                                "width": "33%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Invoice number",
                                                "value": "invoice_number",
                                                "width": "33%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "status",
                                                "width": "100%",
                                                "visible": false
                                            }
                                        ]
                                    },
                                    {
                                        "width": "25%",
                                        "items": []
                                    },
                                    {
                                        "width": "25%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "label": "Called Amount",
                                                "value": "price",
                                                "width": "100%"
