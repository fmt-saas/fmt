{
    "name": "Property Lot",
    "description": "List of property lots.",
    "header": {
        "actions": {
            "ACTION.CREATE" : [
                {
                    "view": "form.create",
                    "description": "Simplified form to ease creation."
                }
            ]
        }
    },
    "layout": {
        "items": [
            {
                "type": "field",
                "label": "Code",
