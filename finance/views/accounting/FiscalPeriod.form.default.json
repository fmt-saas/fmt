{
    "name": "Fiscal Period",
    "actions": [
        {
            "id": "action.preclose",
            "label": "Pre-close",
            "description": "Pre-close the fiscal period. This will generate a proforma Expense Statement.",
            "controller": "core_model_transition",
            "visible1": ["status", "=", "open"],
            "visible": false,
            "visible_desription": "#memo - preclose action is performed through ExpenseStatement",
            "params": {
                "entity": "finance\\accounting\\FiscalPeriod",
                "transition": "preclose",
                "ids": []
            },
            "confirm": true
        },
        {
            "id": "action.reopen",
            "label": "Reopen",
            "description": "Set fiscal period back to pre-close.",
            "controller": "core_model_transition",
            "visible": [["status", "=", "closed"], ["fiscal_year_status", "=", "open"]],
            "params": {
                "entity": "finance\\accounting\\FiscalPeriod",
                "transition": "repreclose",
                "ids": []
            },
            "confirm": true
        }
    ],
    "layout": {
        "groups": [
            {
                "sections": [
                    {
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "50%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "name",
                                                "width": "100%",
                                                "widget": {
                                                    "heading": true,
                                                    "readonly": true
                                                }
                                            },
                                            {
                                                "type": "field",
                                                "value": "date_from",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "date_to",
                                                "width": "50%"
                                            }
                                        ]
                                    },
                                    {
                                        "width": "50%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "label": "Organisation",
                                                "value": "organisation_id",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Condominium",
                                                "value": "condo_id",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Fiscal Year",
                                                "value": "fiscal_year_id",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "fiscal_year_status",
                                                "width": "50%",
                                                "visible": false
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            },
            {
                "sections": [
                    {
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "expense_statements_ids",
                                                "width": "100%"
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            }
        ]
    }
}