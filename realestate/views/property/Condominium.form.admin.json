                                            {
                                                "type": "field",
                                                "label": "Permit date",
                                                "value": "construction_permit_date",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Start date",
                                                "value": "construction_start_date",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Completion date",
                                                "value": "construction_completion_date",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Compliance date",
                                                "value": "construction_compliance_date",
                                                "width": "50%"
                                            }
                                        ]
                                    },
                                    {
                                        "width": "33%",
                                        "items": [
                                            {
                                                "id": "label.regulations",
                                                "type": "label",
                                                "value": "Regulations",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "total_shares",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Creation date",
                                                "value": "condo_creation_date",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Latest update",
                                                "value": "condo_regulations_date",
                                                "width": "100%"
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "label": "Address",
