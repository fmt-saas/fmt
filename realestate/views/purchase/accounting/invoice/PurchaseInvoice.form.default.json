{
    "name": "Invoice",
    "description": "An invoice is a legal document issued by a seller to a buyer that relates to a sale, and is part of the accounting system.",
    "actions": [
        {
            "id": "action.invoice",
            "label": "Validate",
            "description": "To Invoice.",
            "controller": "core_model_transition",
            "visible": false,
            "visible_help": "A purchase invoice should always be posted through its parent DocumentProcess.",
            "visible1": [["state", "=", "instance"], ["status", "=", "proforma"]],
            "params": {
                "entity": "realestate\\purchase\\accounting\\invoice\\PurchaseInvoice",
                "transition": "post",
                "ids": []
            }
        },
        {
            "id": "action.cancel",
            "label": "Cancel",
            "description": "Cancel invoice.",
            "controller": "core_model_do",
            "confirm": true,
            "visible1": false,
            "visible_help": "A purchase invoice should always be cancelled through its parent DocumentProcess.",
            "visible": ["status", "=", "posted"],
            "params": {
                "entity": "realestate\\purchase\\accounting\\invoice\\PurchaseInvoice",
                "action": "cancel",
                "ids": []
            }
        },
        {
            "id": "action.unlock",
            "label": "Unlock",
            "description": "Unlock invoice.",
            "controller": "core_model_do",
            "confirm": true,
            "visible1": false,
            "visible_help": "A purchase invoice should always be cancelled through its parent DocumentProcess.",
            "visible": ["status", "=", "posted"],
            "params": {
                "entity": "realestate\\purchase\\accounting\\invoice\\PurchaseInvoice",
                "action": "unlock",
                "ids": []
            }
        },
        {
            "id": "action.complete",
            "label": "Mark Completed",
            "description": "Mark the invoice as completed.",
            "controller": "core_model_do",
            "visible": [["document_process_status", "=", "assigned"]],
            "params": {
                "entity": "realestate\\purchase\\accounting\\invoice\\PurchaseInvoice",
                "action": "mark_completed",
                "ids": []
            }
        },
        {
            "id": "action.valid",
            "label": "Mark Validated",
            "description": "Mark the invoice as validated.",
            "controller": "core_model_do",
            "visible": [["document_process_status", "=", "completed"]],
            "params": {
                "entity": "realestate\\purchase\\accounting\\invoice\\PurchaseInvoice",
                "action": "mark_validated",
                "ids": []
            }
        },
        {
            "id": "action.cancel",
            "label": "Cancel",
            "description": "Cancel the processing of the invoice. This action will remove the (proforma) invoice and set the Document process to non-drafted. This cannot be undone.",
            "controller": "core_model_do",
            "confirm": true,
            "visible": false,
            "visible1": [
                ["document_process_status", "in", ["assigned", "completed"]]
            ],
            "params": {
                "entity": "realestate\\purchase\\accounting\\invoice\\PurchaseInvoice",
                "action": "mark_cancelled",
                "ids": []
            }
        },
        {
            "id": "action.reverse_completed",
            "label": "Revert",
            "description": "Undo marking the invoice as complete.",
            "controller": "core_model_do",
            "confirm": true,
            "visible": [
                ["document_process_status", "in", ["completed"]]
            ],
            "params": {
                "entity": "realestate\\purchase\\accounting\\invoice\\PurchaseInvoice",
                "action": "reverse_completed",
                "ids": []
            }
        },
        {
            "id": "action.remove",
            "label": "Remove",
            "description": "Remove the invoice and the processing. Use this action when the import was a mistake or the invoice is a duplicate. This action cannot be undone.",
            "controller": "core_model_do",
            "confirm": true,
            "visible": [
                ["document_process_status", "in", ["created", "assigned", "completed"]]
            ],
            "params": {
                "entity": "realestate\\purchase\\accounting\\invoice\\PurchaseInvoice",
                "action": "remove",
                "success_status": 205,
                "ids": []
            }
        },
        {
            "id": "action.post",
            "label": "Post",
            "description": "Post the invoice to the accounting system.",
            "controller": "core_model_transition",
            "visible": [
                ["status", "=", "proforma"],
                ["document_process_status", "=", "validated"]
            ],
            "params": {
                "entity": "realestate\\purchase\\accounting\\invoice\\PurchaseInvoice",
                "transition": "post",
                "ids": []
            }
        },
        {
            "id": "action.create_fundings",
            "label": "Post",
            "description": "Post the invoice to the accounting system.",
            "controller": "core_model_do",
            "visible": [
                ["status", "=", "posted"],
                ["funding_id", "=", null],
                ["has_payment_on_hold", "=", false]
            ],
            "params": {
                "entity": "realestate\\purchase\\accounting\\invoice\\PurchaseInvoice",
                "transition": "create_fundings",
                "ids": []
            }
        }
    ],
    "routes": [
        {
            "id": "item.view_document",
            "label": "View Original Document",
            "description": "",
            "icon": "open_in_new",
            "route": "/?get=documents_document&id=object.document_id",
            "target": "_blank",
            "absolute": true
        },
        {
            "id": "item.document",
            "label": "Document",
            "description": "",
            "icon": "visibility",
            "context": {
                "entity": "documents\\Document",
                "view": "form.default",
                "mode": "view",
                "purpose": "view",
                "domain": [["id", "=", "object.document_id"]]
            },
            "visible": [null, "<>", "object.document_id"]
        },
        {
            "id": "item.view_document_process",
            "label": "Doc Processing",
            "description": "",
            "icon": "visibility",
            "context": {
                "entity": "documents\\processing\\DocumentProcess",
                "view": "form.default",
                "mode": "view",
                "domain": [["id", "=", "object.document_process_id"]]
            }
        }
    ],
    "header": {
        "actions": {
            "ACTION.SAVE": [
                {
                    "id": "SAVE_AND_CONTINUE"
                },
                {
                    "id": "SAVE_AND_VIEW"
                }
            ]
        }
    },
    "layout": {
        "groups": [
            {
                "sections": [
                    {
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "60%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "status",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "value": "document_process_status",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "value": "document_process_id",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "value": "document_id",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "value": "funding_id",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "label": "Condominium",
                                                "value": "condo_id",
                                                "width": "33%",
                                                "visible": true
                                            },
                                            {
                                                "type": "field",
                                                "label": "Condominium Bank Account",
                                                "value": "condo_bank_account_id",
                                                "width": "33%"
                                            },

                                            {
                                                "id": "item.invoice_type",
                                                "type": "field",
                                                "label": "Type",
                                                "value": "invoice_type",
                                                "width": "33%"
                                            },

                                            {
                                                "type": "field",
                                                "label": "Supplier",
                                                "value": "suppliership_id",
                                                "width": "33%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Supplier Bank Account",
                                                "value": "suppliership_bank_account_id",
                                                "width": "33%"
                                            },
                                            {
                                                "type": "label",
                                                "value": "",
                                                "width": "33%"
                                            },

                                            {
                                                "id": "item.emission_date",
                                                "type": "field",
                                                "value": "emission_date",
                                                "width": "16%"
                                            },
                                            {
                                                "id": "item.due_date",
                                                "type": "field",
                                                "value": "due_date",
                                                "width": "16%",
                                                "visible": ["status", "<>", "cancelled"]
                                            },
                                            {
                                                "type": "field",
                                                "label": "Fiscal Year",
                                                "value": "fiscal_year_id",
                                                "width": "33%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Fiscal Period",
                                                "value": "fiscal_period_id",
                                                "width": "33%"
                                            },

                                            {
                                                "id": "item.invoice_number",
                                                "label": "number",
                                                "type": "field",
                                                "value": "supplier_invoice_number",
                                                "width": "33%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "payment_reference",
                                                "width": "33%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "payable_amount",
                                                "width": "25%",
                                                "visible": true
                                            },
                                            {
                                                "type": "field",
                                                "value": "total_vat",
                                                "description": "#todo - should be displayed be the Condo subject to VAT",
                                                "width": "0%",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "value": "price",
                                                "width": "25%",
                                                "visible": false
                                            },

                                            {
                                                "type": "field",
                                                "value": "has_mandate",
                                                "width": "33%"
                                            },

                                            {
                                                "type": "field",
                                                "value": "has_payment_on_hold",
                                                "width": "33%"
                                            },

                                            {
                                                "type": "field",
                                                "value": "on_hold_description",
                                                "width": "33%"
                                            },
                                            {
                                                "type": "label",
                                                "value": "",
                                                "width": "33%",
                                                "visible": ["has_payment_on_hold", "=", false]
                                            },


                                            {
                                                "type": "field",
                                                "label": "Date range",
                                                "value": "has_date_range",
                                                "width": "33%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "posting_date",
                                                "width": "33%",
                                                "visible": ["has_date_range", "=", false]
                                            },
                                            {
                                                "type": "field",
                                                "label": "Posting from",
                                                "value": "date_from",
                                                "width": "33%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Posting to",
                                                "value": "date_to",
                                                "width": "33%"
                                            },

                                            {
                                                "id": "item.description",
                                                "type": "field",
                                                "value": "description",
                                                "width": "66%",
                                                "required": true
                                            },

                                            {
                                                "type": "field",
                                                "label": "Use reserve fund(s)",
                                                "value": "has_fund_usage",
                                                "width": "33%"
                                            },

                                            {
                                                "id": "item.invoice_lines_ids",
                                                "type": "field",
                                                "value": "invoice_lines_ids",
                                                "width": "100%",
                                                "widget": {
                                                    "view": "list.default",
                                                    "header": {
                                                        "layout": "inline",
                                                        "actions": {
                                                            "ACTION.SELECT": false,
                                                            "ACTION.CREATE": false
                                                        }
                                                    },
                                                    "domain": ["condo_id", "=", "object.condo_id"]
                                                }
                                            }
                                        ]
                                    },
                                    {
                                        "visible": ["document_id", "<>", null],
                                        "width": "40%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "document_link",
                                                "width": "100%",
                                                "widget": {
                                                    "type": "pdf",
                                                    "height": 800
                                                }
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            },
            {
                "sections": [
                    {
                        "id": "section.email",
                        "label": "E-mail",
                        "visible": [
                            ["email_subject", "<>", ""],
                            ["email_subject", "is not", null]
                        ],
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "email_subject",
                                                "width": "100%",
                                                "widget": {
                                                    "readonly": true
                                                }
                                            },
                                            {
                                                "type": "field",
                                                "value": "email_body",
                                                "width": "100%",
                                                "widget": {
                                                    "readonly":  true
                                                }
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "section.fund_usage_lines",
                        "label": "Fund usages",
                        "visible": ["has_fund_usage", "=", true],
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "fund_usage_lines_ids",
                                                "width": "100%"
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "section.accounting_entries",
                        "label": "Accounting Entries",
                        "visible": ["status", "in", ["posted", "cancelled"]],
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "accounting_entries_ids",
                                                "width": "100%",
                                                "header": {
                                                    "actions": {
                                                        "ACTION.SELECT": false,
                                                        "ACTION.CREATE": false
                                                    }
                                                }
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "section.fundings",
                        "label": "Fundings",
                        "visible": ["status", "=", "posted"],
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "fundings_ids",
                                                "width": "100%",
                                                "header": {
                                                    "actions": {
                                                        "ACTION.SELECT": false,
                                                        "ACTION.CREATE": false
                                                    }
                                                }
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            }
        ]
    }
}
