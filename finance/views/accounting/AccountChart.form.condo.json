{
    "name": "Chart of Accounts",
    "description": "Condominium Chart of Accounts.",
    "header": {
        "actions": {
            "ACTION.SAVE": [{"id": "SAVE_AND_CONTINUE"}, {"id": "SAVE_AND_CLOSE"}]
        }
    },
    "actions": [
        {
            "id": "action.import_template",
            "label": "Import template",
            "description": "Import accounts from a template.",
            "controller": "finance_accounting_accountchart_import",
            "visible": [["state", "<>", "draft"], ["status", "=", "draft"]]
        },
        {
            "id": "action.activate",
            "label": "Activate",
            "description": "Validate and make the chart active. This action is not reversible.",
            "controller": "core_model_transition",
            "visible": [["state", "<>", "draft"], ["status", "=", "draft"]],
            "params": {
                "entity": "finance\\accounting\\AccountChart",
                "transition": "activation",
                "ids": []
            },
            "confirm": true
        }
    ],
    "layout": {
        "groups": [
            {
                "sections": [
                    {
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "50%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "name",
                                                "width": "100%",
                                                "widget": {
                                                    "heading": true
                                                }
                                            }
                                        ]
                                    },
                                    {
                                        "width": "25%",
                                        "items": []
                                    },
                                    {
                                        "width": "25%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "label": "Condominium",
                                                "value": "condo_id",
                                                "width": "100%"
                                            }
                                        ]
                                    }
                                ]
                            },
                            {
                                "visible": ["state", "<>", "draft"],
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "accounts_ids",
                                                "width": "100%",
                                                "widget": {
                                                    "header": {
                                                        "actions": {
                                                            "ACTION.CREATE": true,
                                                            "ACTION.SELECT": false
                                                        }
                                                    }
                                                }
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            }
        ]
    }
}