{
    "name": "Ownership Transfer",
    "description": "Transfer of Ownership for one or more property lots.",
    "header": {
        "actions": {
            "ACTION.SAVE": [
                {
                    "id": "SAVE_AND_VIEW"
                }
            ]
        }
    },
    "actions": [
        {
            "id": "action.open",
            "label": "Open",
            "description": "Validate data and start the transfer process.",
            "controller": "core_model_transition",
            "visible": [ ["status", "=", "pending"] ],
            "params": {
                "entity": "realestate\\property\\OwnershipTransfer",
                "transition": "open",
                "ids": []
            }
        },
        {
            "id": "action.confirm",
            "label": "Confirm",
            "description": "Validate data and start the transfer process.",
            "controller": "core_model_transition",
            "visible": [ ["status", "in", ["open", "seller_documents_sent"]] ],
            "params": {
                "entity": "realestate\\property\\OwnershipTransfer",
                "transition": "confirm",
                "ids": []
            }
        },
        {
            "id": "action.settle",
            "label": "Settle",
            "description": "Validate data and start the transfer process.",
            "controller": "core_model_transition",
            "visible": [ ["status", "in", ["confirmed", "financial_statement_sent"]] ],
            "params": {
                "entity": "realestate\\property\\OwnershipTransfer",
                "transition": "settle",
                "ids": []
            }
        },
        {
            "id": "action.generate_adjustments",
            "label":     "Generate Adjustments",
            "description": "Generate accounting accounts.",
            "controller": "core_model_do",
            "visible": ["status", "in", ["settled"]],
            "params": {
                "entity": "realestate\\property\\OwnershipTransfer",
                "action": "generate_adjustments",
                "ids": []
            },
            "confirm": false
        },
        {
            "id": "action.perform_transfer",
            "label": "Perform Transfer",
            "description": "Generate accounting accounts.",
            "controller": "core_model_do",
            "visible": ["status", "in", ["settled"]],
            "params": {
                "entity": "realestate\\property\\OwnershipTransfer",
                "action": "perform_transfer",
                "ids": []
            },
            "confirm": false
        }
    ],
    "routes": [
        {
            "id": "route.preview.pdf",
            "label": "Preview mail",
            "description": "Displays all lines but without group.",
            "icon": "print",
            "route": "/?get=realestate_property_OwnershipTransfer_render-pdf&id=object.id",
            "target": "_blank",
            "absolute": true,
            "visible": [["object.id", "<>", "object.id"], ["pending", "<>", "object.status"]]
        }
    ],
    "layout": {
        "groups": [
            {
                "sections": [
                    {
                        "id": "section.main",
                        "label": "Owner & Lots",
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "label",
                                                "value": "Information request",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Date of the information request",
                                                "value": "request_date",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "label",
                                                "value": "Condominium & Owner",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "condo_id",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Current Owner",
                                                "value": "old_ownership_id",
