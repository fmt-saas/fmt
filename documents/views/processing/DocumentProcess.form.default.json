{
    "name": "Document Processing",
    "description": "Document import.",
    "header": {
        "actions": {
            "ACTION.SAVE": [
                {
                    "id": "SAVE_AND_VIEW",
                    "view": "form.default"
                }
            ]
        }
    },
    "routes": [
        {
            "id": "item.document",
            "label": "Document",
            "description": "",
            "icon": "visibility",
            "context": {
                "entity": "documents\\Document",
                "view": "form.default",
                "mode": "view",
                "purpose": "view",
                "domain": [["id", "=", "object.document_id"]]
            },
            "visible": [null, "<>", "object.document_id"]
        },
        {
            "id": "item.invoice",
            "label": "Invoice",
            "description": "",
            "icon": "visibility",
            "context": {
                "entity": "realestate\\purchase\\accounting\\invoice\\PurchaseInvoice",
                "view": "form.default",
                "mode": "view",
                "purpose": "view",
                "domain": [["id", "=", "object.document_invoice_id"]]
            },
            "visible": [null, "<>", "object.document_invoice_id"]
        },
        {
            "id": "item.bank_statement",
            "label": "Bank Statement",
            "description": "",
            "icon": "visibility",
            "context": {
                "entity": "finance\\bank\\BankStatement",
                "view": "form.default",
                "mode": "view",
                "purpose": "view",
                "domain": [["id", "=", "object.document_bank_statement_id"]]
            },
            "visible": [null, "<>", "object.document_bank_statement_id"]
        }
    ],
    "actions": [
        {
            "id": "action.mark_assigned",
            "label": "Mark Assigned",
            "description": "Attempt to mark the processing as `assigned`.",
            "controller": "core_model_transition",
            "params": {
                "entity": "documents\\processing\\DocumentProcess",
                "transition": "assign"
            },
            "visible": [
                ["status", "=", "created"],
                ["has_target_object", "=", true],
                ["document_type_id", "<>", null],
                ["condo_id", "<>", null],
                ["assigned_employee_id", "<>", null]
            ]
        },
        {
            "id": "action.perform_identification",
            "label": "Analyze",
            "description": "Attempt to identify the type of document base on its content.",
            "controller": "core_model_do",
            "params": {
                "entity": "documents\\processing\\DocumentProcess",
                "action": "perform_identification"
            },
            "visible": false,
            "visible1": [
                ["status", "in", ["created", "assigned"]],
                ["document_type_id", "=", null]
            ]
        },
        {
            "id": "action.perform_extraction",
            "label": "Extract",
            "description": "Attempt to extract data from the Attachment.",
            "controller": "core_model_do",
            "visible": false,
            "visible1": [
                ["status", "in", ["created", "assigned"]],
                ["document_type_id", "<>", null],
                ["document_id", "<>", null],
                ["has_document_json", "=", false]
            ],
            "params": {
                "entity": "documents\\processing\\DocumentProcess",
                "action": "perform_extraction",
                "ids": []
            }
        },
        {
            "id": "action.perform_matching",
            "label": "Attempt auto-match",
            "description": "(Re-) attempt to identify condominium & supplier.",
            "controller": "core_model_do",
            "visible": [
                [
                    ["status", "in", ["created", "assigned"]],
                    ["document_type_id", "<>", null],
                    ["document_id", "<>", null],
                    ["has_document_json", "=", true],
                    ["condo_id", "=", null]
                ],
                [
                    ["status", "in", ["created", "assigned"]],
                    ["document_type_id", "<>", null],
                    ["document_id", "<>", null],
                    ["has_document_json", "=", true],
                    ["supplier_id", "=", null]
                ]
            ],
            "params": {
                "entity": "documents\\processing\\DocumentProcess",
                "action": "perform_matching",
                "ids": []
            }
        },
        {
            "id": "action.perform_drafting",
            "label": "Draft target",
            "description": "Attempt to extract data from the Attachment.",
            "controller": "core_model_do",
            "visible": false,
            "visible1": [
                ["status", "in", ["created", "assigned"]],
                ["has_target_object", "=", false],
                ["document_type_id", "<>", null],
                ["condo_id", "<>", null]
            ],
            "params": {
                "entity": "documents\\processing\\DocumentProcess",
                "action": "perform_drafting",
                "ids": []
            }
        },
        {
            "id": "action.attempt_auto_draft",
            "label": "Draft target",
            "description": "Attempt to perform auto-completion based on imported Attachment.",
            "controller": "core_model_do",
            "visible": [
                ["status", "in", ["created", "assigned"]],
                ["has_target_object", "=", false],
                ["document_type_id", "<>", null],
                ["condo_id", "<>", null]
            ],
            "params": {
                "entity": "documents\\processing\\DocumentProcess",
                "action": "attempt_auto_draft",
                "ids": []
            }
        },
        {
            "id": "action.complete",
            "label": "Mark as Complete",
            "description": "Mark the document as completed.",
            "controller": "core_model_transition",
            "visible": false,
            "visible1": [
                ["status", "=", "created"],
                ["has_target_object", "=", true],
                ["has_document_json", "=", true]
            ],
            "params": {
                "entity": "documents\\processing\\DocumentProcess",
                "transition": "complete",
                "ids": []
            }
        },
        {
            "id": "action.validate",
            "label": "Validate",
            "description": "Mark the document as validated.",
            "controller": "core_model_transition",
            "visible": false,
            "visible1": [ ["status", "=", "completed"] ],
            "params": {
                "entity": "documents\\processing\\DocumentProcess",
                "transition": "validate",
                "ids": []
            }
        },
        {
            "id": "action.integrate",
            "label": "Integrate",
            "description": "Integrate the document to accounting.",
            "controller": "core_model_transition",
            "visible": false,
            "visible1": [ ["status", "=", "confirmed"] ],
            "params": {
                "entity": "documents\\processing\\DocumentProcess",
                "transition": "integrate",
                "ids": []
            }
        },
        {
            "id": "action.remove",
            "label": "Delete",
            "description": "Delete the import and the related document.",
            "controller": "core_model_do",
            "params": {
                "entity": "documents\\processing\\DocumentProcess",
                "action": "remove",
                "success_status": 205,
                "ids": []
            },
            "confirm": true,
            "visible": [ ["state", "=", "instance"], ["status", "=", "created"] ]
        }
    ],
    "layout": {
        "groups": [
            {
                "sections": [
                    {
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "50%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "label": "Document",
                                                "value": "document_id",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Condominium",
                                                "value": "condo_id",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Supplier",
                                                "value": "supplier_id",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Assigned Employee",
                                                "value": "assigned_employee_id",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Doc Type",
                                                "value": "document_type_code",
                                                "width": "50%",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "label": "Doc Type",
                                                "value": "has_document_json",
                                                "width": "50%",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "label": "Doc Type",
                                                "value": "document_type_id",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Doc Sub Type",
                                                "value": "document_subtype_id",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Doc Type",
                                                "value": "has_target_object",
                                                "width": "50%",
                                                "visible": true
                                            },
                                            {
                                                "type": "field",
                                                "label": "Invoice",
                                                "value": "document_invoice_id",
                                                "width": "50%",
                                                "widget": {
                                                    "readonly": true,
                                                    "description": "Creation must be made using `draft target` action."
                                                }
                                            },
                                            {
                                                "type": "field",
                                                "label": "Bank Statement",
                                                "value": "document_bank_statement_id",
                                                "width": "50%",
                                                "widget": {
                                                    "readonly": true
                                                }
                                            },
                                            {
                                                "type": "field",
                                                "label": "Report",
                                                "value": "report_html",
                                                "width": "100%",
                                                "widget": {
                                                    "height": 440,
                                                    "readonly": true
                                                }
                                            }
                                        ]
                                    },
                                    {
                                        "width": "50%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "document_link",
                                                "width": "100%",
                                                "visible": [
                                                    [ ["document_type_code", "in", ["invoice", "credit_note"]] ],
                                                    [ ["document_type_code", "=", null] ]
                                                ],
                                                "widget": {
                                                    "type": "pdf",
                                                    "height": 800
                                                }
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            }
        ]
    }
}
