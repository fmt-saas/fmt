{
    "name": "Ownership",
    "actions": [
        {
            "id": "action.validate",
            "label": "Validate",
            "description": "Validate & Generate accounting accounts.",
            "controller": "core_model_transition",
            "params": {
                "entity": "realestate\\ownership\\Ownership",
                "transition": "validate",
                "ids": []
            },
            "confirm": false
        },
        {
            "id": "action.print_funds_request",
            "label": "Print Funds Request",
            "icon": "savings",
            "description": "Generate the funds request document for a given fiscal year.",
            "controller": "realestate_ownership_fundrequests_print-pdf",
            "params": {
                "view_id": "print.default",
                "debug": false
            }
        },
        {
            "id": "action.generate_history",
            "label": "Generate History",
            "description": "Generate Property Lots Ownership history.",
            "controller": "core_model_do",
            "params": {
                "entity": "realestate\\ownership\\Ownership",
                "action": "generate_history",
                "ids": []
            }
        }
    ],
    "routes": [
        {
            "id": "item.owner_statements",
            "label": "Owner Statements",
            "description": "",
            "icon": "group",
            "context": {
                "entity": "finance\\accounting\\ownerAccountStatement\\collect",
                "view": "list.default",
                "domain": ["ownership_id", "=", "object.id"]
            }
        }
    ],
