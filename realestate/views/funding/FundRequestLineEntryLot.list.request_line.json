{
    "name": "Fund Request Lot Entries",
    "description": "Display the lot-level breakdown of a fund request line.",
    "header": {
        "actions": {
            "ACTION.CREATE": false
        }
    },
    "group_by": [
        {
            "open": false,
            "field": "ownership_id",
            "colspan": 1,
            "operations": {
                "apportionment_shares": {
                    "operation": "SUM"
                },
                "property_lot_id": {
                    "operation": "COUNT",
                    "align": "left"
                },
                "allocated_amount": {
                    "operation": "SUM",
                    "usage": "amount/money:2"
                }
            }
        }
    ],
    "operations": {
        "total": {
            "allocated_amount": {
                "operation": "SUM",
                "usage": "amount/money:2"
            },
            "apportionment_shares": {
                "operation": "SUM"
            }
        }
    },
    "layout": {
        "items": [
            {
                "type": "field",
                "label": "Ownership",
                "value": "ownership_id",
                "width": "50%"
            },
            {
                "type": "field",
                "label": "Property lot",
                "value": "property_lot_id",
                "width": "20%"
            },
            {
                "type": "field",
                "label": "Shares",
                "value": "apportionment_shares",
                "width": "15%"
            },
            {
                "type": "field",
                "value": "allocated_amount",
                "width": "15%"
            }
        ]
    }
}
