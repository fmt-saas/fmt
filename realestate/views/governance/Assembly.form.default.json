{
    "name": "Assembly",
    "description": "Interface for model definition classes.",
    "actions": [
        {
            "id": "action.publish",
            "label": "Publish",
            "description": "Publish the assembly (ready for sending).",
            "controller": "core_model_transition",
            "params": {
                "entity": "realestate\\governance\\Assembly",
                "transition": "publish"
            },
            "visible": ["status", "=", "pending"]
        },
        {
            "id": "action.revert_publish",
            "label": "Revert to draft",
            "description": "Revet assembly to draft (to allow edition).",
            "controller": "core_model_transition",
            "params": {
                "entity": "realestate\\governance\\Assembly",
                "transition": "revert_publish"
            },
            "visible": ["status", "=", "published"]
        },
        {
            "id": "action.refresh_owners",
            "label": "Refresh Owners",
            "description": "Refresh Owners list, in case a transfer impacted the list in the meantime.",
            "controller": "core_model_do",
            "params": {
                "entity": "realestate\\governance\\Assembly",
                "action": "generate_ownerships",
                "ids": []
            },
            "confirm": true,
            "visible": ["status", "=", "published"]
        },
        {
            "id": "action.invite",
            "label": "Create Invites",
            "description": "Generate & Send invites.",
            "controller": "core_model_transition",
            "params": {
                "entity": "realestate\\governance\\Assembly",
                "transition": "send"
            },
            "visible": ["status", "=", "published"]
        },
        {
            "id": "action.sent",
            "label": "Mark as Sent",
            "description": "Mark invitations as sent.",
            "controller": "core_model_transition",
            "params": {
                "entity": "realestate\\governance\\Assembly",
                "transition": "sent"
            },
            "visible": ["status", "=", "sending"]
        },
        {
            "id": "action.open",
            "label": "Open Assembly",
            "description": "Open the assembly (mark as in progress).",
            "controller": "core_model_transition",
            "params": {
                "entity": "realestate\\governance\\Assembly",
                "transition": "open"
            },
            "visible": ["status", "=", "sent"]
        },
        {
            "id": "action.close_attendance",
            "label": "Close Attendance",
            "description": "Close the attendance part of the session: no more attendance will be registered afterward.",
            "controller": "core_model_do",
            "params": {
                "entity": "realestate\\governance\\Assembly",
                "action": "close_attendance",
                "ids": []
            },
            "confirm": true,
            "visible": [ ["status", "=", "in_progress"], ["step", "=", "opening"] ]
        },
        {
            "id": "action.validate_proxies",
            "label": "Validate Mandates",
            "description": "Validate the Attendees' mandates and step to representation validation.",
            "controller": "core_model_do",
            "params": {
                "entity": "realestate\\governance\\Assembly",
                "action": "validate_proxies"
            },
            "visible":  [ ["status", "=", "in_progress"], ["step", "=", "mandate_validation"] ]
        },
        {
            "id": "action.validate_attendance",
            "label": "Validate Attendance",
            "description": "Step to attendance validation.",
            "controller": "core_model_do",
            "params": {
                "entity": "realestate\\governance\\Assembly",
                "action": "validate_representations"
            },
            "visible":  [ ["status", "=", "in_progress"], ["step", "=", "representation_validation"] ]
        },
        {
            "id": "action.validate_assembly",
            "label": "Validate Assembly",
            "description": "Attempts to validate the Assembly.",
            "controller": "core_model_do",
            "params": {
                "entity": "realestate\\governance\\Assembly",
                "action": "validate_assembly"
            },
            "visible": [ ["is_valid", "=", true], ["status", "=", "in_progress"], ["step", "=", "assembly_validation"] ]
        },
        {
            "id": "action.adjourn_assembly",
            "label": "Adjourn Assembly",
            "description": "Close the Assembly, mark it as adjourned.",
            "controller": "core_model_transition",
            "params": {
                "entity": "realestate\\governance\\Assembly",
                "transition": "adjourn"
            },
            "visible": [ ["is_valid", "=", false], ["status", "=", "in_progress"], ["step", "=", "assembly_validation"] ]
        },
        {
            "id": "action.schedule_second_session",
            "label": "Schedule second session",
            "description": "Schedule a second session for the Assembly.",
            "controller": "core_model_do",
            "params": {
                "entity": "realestate\\governance\\Assembly",
                "action": "schedule_second_session"
            },
            "visible": [ ["is_valid", "=", false], ["status", "=", "adjourned"], ["has_second_session", "=", false] ]
        },
        {
            "id": "action.check_invites",
            "label": "Check invites",
            "help": "This is a temporary way to trigger the action which is intended to be automated",
            "description": "Checks if all invites have been sent.",
            "controller": "realestate_governance_Assembly_check-invite",
            "visible": [ ["status", "=", "sent"] ]
        },
        {
            "id": "action.add_attendee",
            "label": "Add attendee",
            "description": "Register an attendee, collect its mandates and its signature.",
            "component": {
                "name": "addAttendee",
                "data": {
                    "condo_id": "object.condo_id",
                    "assembly_id": "object.id"
                }
            },
            "visible": [ ["status", "=", "in_progress"], ["step", "=", "opening"] ]
        }
    ],
    "routes": [
        {
            "id": "route.preview_invite",
            "type": "entry",
            "label": "Preview Invite",
            "icon": "preview",
            "description": "",
            "route": "/?get=realestate_governance_Assembly_invitation_render-pdf&id=object.id",
            "target": "_blank",
            "absolute": true
        },
        {
            "id": "route.view_attendance_register",
            "type": "entry",
            "label": "View Attendance register",
            "icon": "print",
            "description": "View printable attendance register.",
            "route": "/?get=realestate_governance_Assembly_attendanceregister_fetch&id=object.id",
            "target": "_blank",
            "absolute": true,
            "visible": [
                [
                    ["status", "in", ["held", "adjourned"]]
                ],
                [
                    ["status", "=", "in_progress"],
                    ["step", "=", "agenda_processing"]
                ]
            ]
        }
    ],
    "layout": {
        "groups": [
            {
                "sections": [
                    {
                        "id": "section.details",
                        "label": "Details",
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "50%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "name",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "assembly_date",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "assembly_type",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "assembly_location",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Assembly Organizer",
                                                "value": "assembly_organizer_identity_id",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "session_time_start",
                                                "width": "50%",
                                                "visible": ["status", "not in", ["pending", "published", "sending", "sent"]]
                                            },
                                            {
                                                "type": "field",
                                                "value": "session_time_end",
                                                "width": "50%",
                                                "visible": ["status", "not in", ["pending", "published", "sending", "sent"]]
                                            },
                                            {
                                                "type": "field",
                                                "value": "status",
                                                "width": "100%",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "value": "step",
                                                "width": "100%",
                                                "visible": false
                                            }
                                        ]
                                    },
                                    {
                                        "width": "25%",
                                        "items": []
                                    },
                                    {
                                        "width": "25%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "label": "Condominium",
                                                "value": "condo_id",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Template",
                                                "value": "assembly_template_id",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Minutes",
                                                "value": "minutes_document_id",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "is_second_session",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "has_second_session",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "second_session_assembly_id",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "related_assembly_id",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "is_valid",
                                                "width": "100%",
                                                "visible": ["step", "in", ["assembly_validation", "agenda_processing"]]
                                            },
                                            {
                                                "type": "field",
                                                "value": "invalidity_reason",
                                                "width": "100%"
                                            }
                                        ]
                                    }
                                ]
                            },
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "heading_text_call",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "closing_text_call",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "heading_text_minutes",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "closing_text_minutes",
                                                "width": "100%"
                                            }
                                        ]
                                    }
                                ]
                            }

                        ]
                    },
                    {
                        "id": "section.resolutions",
                        "label": "Resolutions",
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "assembly_items_ids",
                                                "width": "100%"
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "section.owners",
                        "label": "Owners",
                        "visible": ["status", "<>", "pending"],
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "count_owners",
                                                "width": "25%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "count_represented_owners",
                                                "width": "25%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "count_shares",
                                                "width": "25%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "count_represented_shares",
                                                "width": "25%"
                                            }
                                        ]
                                    }
                                ]
                            },
                            {

                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "ownerships_ids",
                                                "width": "100%"
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "section.invites",
                        "label": "Invites",
                        "visible": ["status", "not in", ["pending", "published"]],
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "assembly_invitations_ids",
                                                "width": "100%"
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "section.proxies",
                        "label": "Mandates",
                        "visible": ["status", "not in", ["pending", "published", "sending", "sent"]],
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "assembly_proxies_ids",
                                                "width": "100%"
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "section.attendees",
                        "label": "Attendees",
                        "visible": ["status", "not in", ["pending", "published", "sending", "sent"]],
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "signed_attendance_register_document_id",
                                                "width": "50%",
                                                "visible": ["signed_attendance_register_document_id", "is not", null]
                                            }
                                        ]
                                    }
                                ]
                            },
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "assembly_attendees_ids",
                                                "width": "100%"
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "section.representations",
                        "label": "Representations",
                        "visible": ["status", "not in", ["pending", "published", "sending", "sent"]],
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "assembly_representations_ids",
                                                "width": "100%"
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            }
        ]
    }
}