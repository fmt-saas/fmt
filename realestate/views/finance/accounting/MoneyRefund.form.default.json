{
    "name": "Money Refund",
    "description": "A MoneyRefund is a specific type of Miscellaneous Operation designed to generate entries and funding for tracking a refund from an internal bank account.",
    "header": {
        "actions": {
            "ACTION.SAVE": [
                {
                    "id": "SAVE_AND_VIEW",
                    "view": "form.default"
                }
            ]
        }
    },
    "actions": [
        {
            "id": "action.publish",
            "label": "Publish",
            "description": "Publish the Money Refund for validation.",
            "controller": "core_model_transition",
            "visible": [ ["status", "=", "pending"] ],
            "params": {
                "entity": "realestate\\finance\\accounting\\MoneyRefund",
                "transition": "publish",
                "ids": []
            }
        },
        {
            "id": "action.post",
            "label": "Post",
            "description": "Mark the refund as posted/initiated.",
            "controller": "core_model_transition",
            "visible": [ ["status", "=", "proforma"] ],
            "params": {
                "entity": "realestate\\finance\\accounting\\MoneyRefund",
                "transition": "post",
                "ids": []
            }
        },
        {
            "id": "action.complete",
            "label": "Complete",
            "description": "Mark the refund as completed.",
            "controller": "core_model_transition",
            "visible": [ ["status", "=", "posted"] ],
            "params": {
                "entity": "realestate\\finance\\accounting\\MoneyRefund",
                "transition": "complete",
                "ids": []
            }
        }
    ],
    "layout": {
        "groups": [
            {
                "sections": [
                    {
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "50%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "condo_id",
                                                "width": "0%",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "value": "status",
                                                "width": "0%",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "value": "amount",
                                                "width": "33%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "posting_date",
                                                "width": "33%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "description",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Origin account",
                                                "value": "bank_account_id",
                                                "width": "66%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Origin balance",
                                                "value": "account_available_balance",
                                                "width": "33%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Owner",
                                                "value": "ownership_id",
                                                "width": "33%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Ownership account",
                                                "value": "ownership_bank_account_id",
                                                "width": "66%",
                                                "visible": ["ownership_id", "<>", null]
                                            }
                                        ]
                                    },
                                    {
                                        "width": "25%"
                                    },
                                    {
                                        "width": "25%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "label": "Fiscal year",
                                                "value": "fiscal_year_id",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Fiscal period",
                                                "value": "fiscal_period_id",
                                                "width": "100%"
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            },
            {
                "sections": [
                    {
                        "id": "section.fundings",
                        "label": "Fundings",
                        "visible": [["state", "<>", "draft"], ["status", "in", ["posted", "completed"]]],
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "fundings_ids",
                                                "width": "100%"
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "section.accounting_entries",
                        "label": "Accounting Entries",
                        "visible": ["status", "in", ["posted", "completed"]],
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "accounting_entries_ids",
                                                "width": "100%"
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            }
        ]
    }
