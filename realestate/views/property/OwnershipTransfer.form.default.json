{
    "name": "Ownership Transfer",
    "description": "Transfer of Ownership for one or more property lots.",
    "header": {
        "actions": {
            "ACTION.SAVE": [
                {
                    "id": "SAVE_AND_VIEW"
                }
            ]
        }
    },
    "actions": [
        {
            "id": "action.perform_transfer",
            "label": "Perform Transfer",
            "description": "Generate accounting accounts.",
            "controller": "core_model_do",
            "params": {
                "entity": "realestate\\property\\OwnershipTransfer",
                "action": "perform_transfer",
                "ids": []
            },
            "confirm": false
        },
        {
            "id": "action.open",
            "label": "Open",
            "description": "Validate data and start the transfer process.",
            "controller": "core_model_transition",
            "visible": [ ["status", "=", "draft"] ],
            "params": {
                "entity": "realestate\\property\\OwnershipTransfer",
                "transition": "open",
                "ids": []
            }
        },
        {
            "id": "action.generate_balances",
            "label": "Compute balances",
            "description": "Compute condominium funds balances.",
            "controller": "core_model_do",
            "params": {
                "entity": "realestate\\property\\OwnershipTransfer",
                "action": "generate_fund_balance_lines"
            }
        }
    ],
    "layout": {
        "groups": [
            {
                "sections": [
                    {
                        "id": "section.main",
                        "label": "Owner & Lots",
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "50%",
                                        "items": [
                                            {
                                                "type": "label",
                                                "value": "Condominium & Owner",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "condo_id",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "property_lot_id",
                                                "width": "50%",
                                                "visible": ["condo_id", "<>", null],
                                                "widget": {
                                                    "header": {
                                                        "actions": {
                                                            "ACTION.CREATE": false
                                                        }
                                                    }
                                                }
                                            },
                                            {
                                                "type": "field",
                                                "label": "Current Owner",
                                                "value": "old_ownership_id",
                                                "width": "50%",
                                                "visible": ["condo_id", "<>", null],
                                                "widget": {
                                                    "header": {
                                                        "actions": {
                                                            "ACTION.CREATE": false
                                                        }
                                                    }
                                                }
                                            }
                                        ]
                                    },
                                    {
                                        "width": "50%",
                                        "visible": [["condo_id", "<>", null], ["old_ownership_id", "<>", null]],
                                        "items": [
                                            {
                                                "type": "label",
                                                "value": "Selected Property Lots",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "property_lots_ids",
                                                "width": "100%",
                                                "widget": {
                                                    "header": {
                                                        "layout": "inline",
                                                        "actions": {
                                                            "ACTION.SELECT": true,
                                                            "ACTION.CREATE": false
                                                        }
                                                    }
                                                }
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "section.information",
                        "label": "Information",
                        "visible": [["condo_id", "<>", null], ["old_ownership_id", "<>", null]],
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "label": "Date of the notary request",
                                                "value": "request_date"
                                            }
                                        ]
                                    }
                                ]
                            },
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "label": "Condominium funds balances",
                                                "value": "fund_balances_ids"
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "section.new_owner",
                        "label": "New Owner",
                        "visible": [["condo_id", "<>", null], ["old_ownership_id", "<>", null]],
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "50%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "label": "Existing Ownership",
                                                "value": "is_existing_new_ownership"
                                            },
                                            {
                                                "type": "field",
                                                "label": "New Owner",
                                                "value": "new_ownership_id",
                                                "width": "100%",
                                                "widget": {
                                                    "header": {
                                                        "actions": {
                                                            "ACTION.CREATE": false
                                                        }
                                                    }
                                                }
                                            }
                                        ]
                                    },
                                    {
                                        "width": "16%",
                                        "items": []
                                    },
                                    {
                                        "width": "33%",
                                        "visible": ["has_suggested_identity", "=", true],
                                        "items": [
                                            {
                                                "type": "label",
                                                "value": "Suggested identity",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Accept ?",
                                                "value": "is_accepted_suggested_identity",
                                                "width": "50%",
                                                "visible": ["has_suggested_identity", "=", true]
                                            }
                                        ]
                                    }
                                ]
                            },
                            {
                                "visible": ["is_existing_new_ownership", "=", false],
                                "columns": [
                                    {
                                        "width": "50%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "label": "firstname",
                                                "value": "identity_firstname",
                                                "width": "33%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "lastname",
                                                "value": "identity_lastname",
                                                "width": "33%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Citizen ID",
                                                "value": "identity_citizen_identification",
                                                "width": "33%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Email",
                                                "value": "identity_email",
                                                "width": "25%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Phone",
                                                "value": "identity_phone",
                                                "width": "25%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "iban",
                                                "value": "identity_bank_account_iban",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "street",
                                                "value": "identity_address_street",
                                                "width": "66%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "dispatch",
                                                "value": "identity_address_dispatch",
                                                "width": "33%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "zip",
                                                "value": "identity_address_zip",
                                                "width": "25%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "city",
                                                "value": "identity_address_city",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "country",
                                                "value": "identity_address_country",
                                                "width": "25%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "gender",
                                                "value": "identity_gender",
                                                "width": "33%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "title",
                                                "value": "identity_title",
                                                "width": "33%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "lang",
                                                "value": "identity_lang_id",
                                                "width": "33%"
                                            }
                                        ]
                                    },
                                    {
                                        "width": "16%",
                                        "items": []
                                    },
                                    {
                                        "width": "33%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "has_suggested_identity",
                                                "width": "0%",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "value": "suggested_identity_uuid",
                                                "width": "0%",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "label": "Suggested Identity details",
                                                "value": "suggested_identity_log",
                                                "width": "100%",
                                                "visible": ["has_suggested_identity", "=", true],
                                                "widget": {
                                                    "height": "500"
                                                }
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "section.transfer_details",
                        "label": "Transfer",
                        "visible": [["condo_id", "<>", null], ["old_ownership_id", "<>", null], ["new_ownership_id", "<>", null]],
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "50%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "transfer_date"
                                            }
                                        ]
                                    },
                                    {
                                        "width": "50%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "adjustments_ids",
                                                "widget": {
                                                    "header": {
                                                        "layout": "inline"
                                                    },
                                                    "view": "list.transfer",
                                                    "domain": ["adjustment_type", "=", "reimburse"]
                                                }
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "section.notary_deed",
                        "label": "Notary Deed",
                        "visible": [["condo_id", "<>", null], ["old_ownership_id", "<>", null], ["new_ownership_id", "<>", null], ["status", "=", "open"]],
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "50%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "transfer_date"
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            }
        ]
    }
}