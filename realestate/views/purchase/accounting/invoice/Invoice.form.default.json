{
    "name": "Invoice",
    "description": "An invoice is a legal document issued by a seller to a buyer that relates to a sale, and is part of the accounting system.",
    "actions": [
        {
            "id": "action.invoice",
            "label": "Validate",
            "description": "To Invoice.",
            "controller": "core_model_transition",
            "visible": [["state", "=", "instance"], ["status", "=", "proforma"]],
            "params": {
                "entity": "realestate\\purchase\\accounting\\invoice\\Invoice",
                "transition": "post",
                "ids": []
            }
        },
        {
            "id": "action.cancel",
            "label": "Cancel",
            "description": "Cancel invoice.",
            "controller": "core_model_transition",
            "confirm": true,
            "visible": ["status", "=", "posted"],
            "params": {
                "entity": "realestate\\purchase\\accounting\\invoice\\Invoice",
                "transition": "cancel",
                "ids": []
            }
        }
    ],
    "routes": [
        {
            "id": "item.import_invoice",
            "label": "Import Document",
            "description": "",
            "icon": "file_upload",
            "context": {
                "entity": "realestate\\purchase\\accounting\\invoice\\Invoice",
                "view": "form.import",
                "mode": "edit",
                "domain": [["id", "=", "object.id"]]
            },
            "visible": ["document_id", "=", null]
        },
        {
            "id": "item.view_invoice",
            "label": "View Document",
            "description": "",
            "icon": "open_in_new",
            "route": "/?get=documents_document&id=object.document_id",
            "target": "_blank",
            "absolute": true,
            "visible": ["document_id", "<>", null]
        }
    ],
    "layout": {
        "groups": [
            {
                "sections": [
                    {
                        "id": "section.encoding",
                        "label": "Encoding",
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "status",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "value": "document_id",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "label": "Condominium",
                                                "value": "condo_id",
                                                "width": "50%",
                                                "visible": false
                                            },
                                            {
                                                "id": "item.description",
                                                "type": "field",
                                                "value": "description",
                                                "width": "50%",
                                                "widget": {
                                                    "heading": true
                                                }
                                            },
                                            {
                                                "id": "item.invoice_type",
                                                "type": "field",
                                                "label": "Type",
                                                "value": "invoice_type",
                                                "width": "25%"
                                            },
                                            {
                                                "id": "item.emission_date",
                                                "type": "field",
                                                "value": "emission_date",
                                                "width": "25%"
                                            },


                                            {
                                                "type": "field",
                                                "label": "Supplier",
                                                "value": "suppliership_id",
                                                "width": "50%"
                                            },
                                            {
                                                "id": "item.invoice_number",
                                                "label": "number",
                                                "type": "field",
                                                "value": "supplier_invoice_number",
                                                "width": "25%"
                                            },
                                            {
                                                "id": "item.due_date",
                                                "type": "field",
                                                "value": "due_date",
                                                "width": "25%"
                                            },

                                            {
                                                "type": "field",
                                                "label": "Bank Account",
                                                "value": "suppliership_bank_account_id",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "price",
                                                "width": "25%",
                                                "readonly": true
                                            },
                                            {
                                                "type": "field",
                                                "value": "payment_reference",
                                                "width": "25%"
                                            },


                                            {
                                                "type": "field",
                                                "label": "Date range",
                                                "value": "has_date_range",
                                                "width": "25%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "posting_date",
                                                "width": "25%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "posting_date",
                                                "width": "50%",
                                                "visible": ["has_date_range", "=", false]
                                            },
                                            {
                                                "type": "field",
                                                "label": "Posting from",
                                                "value": "date_from",
                                                "width": "25%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Posting to",
                                                "value": "date_to",
                                                "width": "25%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Fiscal Year",
                                                "value": "fiscal_year_id",
                                                "width": "25%",
                                                "visible": false
                                            },
                                            {
                                                "id": "item.invoice_lines_ids",
                                                "type": "field",
                                                "value": "invoice_lines_ids",
                                                "width": "100%",
                                                "widget": {
                                                    "view": "list.default",
                                                    "header": {
                                                        "layout": "inline",
                                                        "actions": {
                                                            "ACTION.SELECT": false,
                                                            "ACTION.CREATE": false
                                                        }
                                                    },
                                                    "domain": ["condo_id", "=", "object.condo_id"]
                                                }
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "section.advanced",
                        "label": "Advanced",
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "label": "Use reserve fund(s)",
                                                "value": "has_fund_usage",
                                                "width": "25%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Immediate reinvoicing",
                                                "value": "has_instant_reinvoice",
                                                "width": "25%"
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "section.fund_usage_lines",
                        "label": "Fund usages",
                        "visible": ["has_fund_usage", "=", true],
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "fund_usage_lines_ids",
                                                "width": "100%"
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "section.accounting_entries",
                        "label": "Accounting Entries",
                        "visible": ["status", "=", "posted"],
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "accounting_entries_ids",
                                                "width": "100%",
                                                "header": {
                                                    "actions": {
                                                        "ACTION.SELECT": false,
                                                        "ACTION.CREATE": false
                                                    }
                                                }
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "section.fundings",
                        "label": "Fundings",
                        "visible": ["status", "=", "posted"],
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "fundings_ids",
                                                "width": "100%",
                                                "header": {
                                                    "actions": {
                                                        "ACTION.SELECT": false,
                                                        "ACTION.CREATE": false
                                                    }
                                                }
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            }
        ]
    }
}
