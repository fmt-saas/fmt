{
    "name": "Invoice Lines",
    "description": "This view is intended for displaying the invoice lines.",
    "operations": {
        "total": {
            "price": {
                "operation": "SUM",
                "usage": "amount/money:2"
            }
        }
    },
    "header": {
        "layout": "inline",
        "actions": {
            "ACTION.CREATE": false,
            "ACTION.CREATE_INLINE": true
        }
    },
    "sort": "asc",
    "limit": 100,
    "layout": {
        "items": [
            {
                "type": "field",
                "value": "condo_id",
                "width": "20%",
                "visible": false
            },
            {
                "type": "field",
                "value": "invoice_id",
                "width": "20%",
                "visible": false
            },
            {
                "type": "field",
                "value": "qty",
                "width": "20%",
                "visible": false
            },
            {
                "type": "field",
                "value": "unit_price",
                "width": "20%",
                "visible": false
            },
            {
                "type": "field",
                "value": "is_apportionable",
                "width": "20%",
                "visible": false
            },
            {
                "type": "field",
                "label": "Account",
                "value": "expense_account_id",
                "width": "30%",
                "widget": {
                    "header": {
                        "actions":{
                            "ACTION.CREATE": false,
                            "ACTION.OPEN": false
                        }
                    }
                }
            },
            {
                "type": "field",
                "label": "Apport.",
                "value": "apportionment_id",
                "width": "25%",
                "widget": {
                    "header": {
                        "actions":{
                            "ACTION.CREATE": false,
                            "ACTION.OPEN": false
                        }
                    }
                }
            },
            {
                "type": "field",
                "label": "Private",
                "value": "is_private_expense",
                "width": "8%"
            },
            {
                "type": "field",
                "label": "tenant",
                "value": "tenant_share",
                "width": "8%"
            },
            {
                "type": "field",
                "label": "vat",
                "value": "vat_rate",
                "width": "8%"
            },
            {
                "type": "field",
                "value": "price",
                "width": "10%"
            }
        ]
    }
}
