{
    "name": "Assembly Template",
    "layout": {
        "interactions": {
            "autofocus": false
        },
        "groups": [
            {
                "sections": [
                    {
                        "id": "section.details",
                        "label": "Details",
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "assembly_template_id",
                                                "width": "50%",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "value": "name",
                                                "width": "75%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "code",
                                                "width": "25%"
                                            }
                                        ]
                                    }
                                ]
                            },
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "is_group",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "has_parent_group",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "parent_group_id",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "has_vote_required",
                                                "width": "25%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "has_choices",
                                                "width": "25%",
                                                "visible": false
                                            },
                                            {
                                                "type": "label",
                                                "value": "",
                                                "width": "25%",
                                                "visible": ["has_vote_required", "=", false]
                                            },
                                            {
                                                "type": "field",
                                                "value": "majority",
                                                "width": "25%",
                                                "visible": ["has_choices", "=", false]
                                            },
                                            {
                                                "id": "label.choices_notice",
                                                "type": "label",
                                                "value": "Please provide choices.",
                                                "width": "25%",
                                                "visible": ["has_choices", "=", true]
                                            },
                                            {
                                                "type": "field",
                                                "value": "apportionment_code",
                                                "width": "25%"
                                            }
                                        ]
                                    }
                                ]
                            },
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "description_call",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "description_minutes",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "description_ballot",
                                                "width": "100%"
                                            }
                                        ]
                                    }
                                ]
                            },
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "children_items_ids",
                                                "width": "100%",
                                                "widget": {
                                                    "view": "list.item"
                                                }
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "section.choices",
                        "label": "Choices",
                        "visible": [["has_vote_required", "=", true], ["has_choices", "=", true]],
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "assembly_item_choices_ids",
                                                "width": "100%"
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            }
        ]
    }
}