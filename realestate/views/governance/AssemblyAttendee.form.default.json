{
    "name": "Assembly Attendee",
    "description": "Represents an attendee at a condominium assembly, which can be an owner or a proxy (not necessarily an owner), or an owner with proxy from other owners.",
    "header": {
        "actions": {
            "ACTION.SAVE": [
                {"id": "SAVE_AND_CONTINUE"},
                {"id": "SAVE_AND_VIEW"},
                {"id": "SAVE_AND_CLOSE"}
            ]
        }
    },
    "layout": {
        "groups": [
            {
                "sections": [
                    {
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "condo_id",
                                                "width": "100%",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "value": "assembly_id",
                                                "width": "100%",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "value": "attendance_register_document_id",
                                                "width": "100%",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "value": "identity_id",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "has_mandate",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "attendee_role",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Signature",
                                                "value": "document_signature_id",
                                                "width": "100%",
                                                "widget": {
                                                    "component": {
                                                        "name": "createSignature",
                                                        "data": {
                                                            "document_id": "object.attendance_register_document_id",
                                                            "identity_id": "object.identity_id"
                                                        }
                                                    }
                                                }
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            },
            {
                "visible": [["state", "=", "instance"], ["has_mandate", "=", true]],
                "sections": [
                    {
                        "id":"section.proxies",
                        "label": "Mandates",
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "assembly_proxies_ids",
                                                "width": "100%"
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id":"section.owners",
                        "label": "Owners",
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "assembly_representations_ids",
                                                "width": "100%"
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            }
        ]
    }
}