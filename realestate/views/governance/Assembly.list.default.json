{
    "name": "Assemblies",
    "description": "Overview of scheduled assemblies and their status.",
    "header": {
        "selection": {
            "actions": [
                {"id": "ACTION.EDIT_INLINE", "visible": false},
                {"id": "ACTION.CLONE", "visible": false},
                {
                    "id": "action.duplicate",
                    "label": "Clone Assembly",
                    "icon": "content_copy",
                    "controller": "realestate_governance_Assembly_clone"
                }
            ]
        }
    },
    "order": "assembly_date",
    "sort": "desc",
    "controller": "realestate_governance_Assembly_collect",
    "layout": {
        "items": [
            {
                "type": "field",
                "value": "id",
                "width": "10%",
                "visible": false
            },
            {
                "type": "field",
                "value": "condo_id",
                "width": "15%",
                "sortable": true
            },
            {
                "type": "field",
                "value": "name",
                "width": "20%"
            },
            {
                "type": "field",
                "value": "assembly_date",
                "width": "10%",
                "sortable": true,
                "widget": {
                    "usage": "date/plain.short"
                }
            },
            {
                "type": "field",
                "value": "assembly_location",
                "width": "15%"
            },
            {
                "type": "field",
                "value": "assembly_type",
                "width": "10%",
                "sortable": true
            },
            {
                "type": "field",
                "value": "is_second_session",
                "width": "8%"
            },
            {
                "type": "field",
                "value": "session_time_start",
                "width": "8%"
            },
            {
                "type": "field",
                "value": "status",
                "width": "10%",
                "sortable": true
            },
            {
                "type": "field",
                "value": "step",
                "width": "15%"
            }
        ]
    }
}
