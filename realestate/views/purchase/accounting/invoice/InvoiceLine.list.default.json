{
    "name": "Invoice Lines",
    "description": "This view is intended for displaying the invoice lines.",
    "operations": {
        "total": {
            "price": {
                "operation": "SUM",
                "usage": "amount/money:2"
            }
        }
    },
    "sort": "asc",
    "limit": 100,
    "layout": {
        "items": [
            {
                "id": "item.name",
                "type": "field",
                "value": "name",
                "width": "20%"
            },
            {
                "type": "field",
                "label": "Expense Account",
                "value": "expense_account_id",
                "width": "20%"
            },
            {
                "type": "field",
                "label": "Apportionment",
                "value": "apportionment_id",
                "width": "20%"
            },
            {
                "type": "field",
                "label": "tenant",
                "value": "tenant_share",
                "width": "10%"
            },
            {
                "type": "field",
                "label": "owner",
                "value": "owner_share",
                "width": "10%"
            },
            {
                "type": "field",
                "value": "vat_rate",
                "width": "10%"
            },
            {
                "type": "field",
                "value": "price",
                "width": "15%"
            }
        ]
    }
}
