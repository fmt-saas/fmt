{
    "name": "Fund Request",
    "header": {
        "actions": {
            "ACTION.SAVE": [
                {"id": "SAVE_AND_CONTINUE"},
                {"id": "SAVE_AND_VIEW"},
                {"id": "SAVE_AND_CLOSE"}
            ]
        }
    },
    "description": "",
    "actions": [
        {
            "id": "action.generate_allocation",
            "label": "Generate allocation",
            "description": "Generate the lines of the fund request.",
            "controller": "core_model_do",
            "params": {
                "entity": "realestate\\funding\\FundRequest",
                "action": "generate_allocation"
            },
            "visible": ["status", "=", "active"]
        },
        {
            "id": "action.generate_executions",
            "label": "Generate executions",
            "description": "Schedule the executions of the fund request.",
            "controller": "core_model_do",
            "params": {
                "entity": "realestate\\funding\\FundRequest",
                "action": "generate_executions"
            },
            "visible": ["status", "=", "active"]
        },
        {
            "id": "action.activate",
            "label": "Activate",
            "description": "Validate Fund request and mark it as active (this cannot be undone).",
            "controller": "core_model_transition",
            "params": {
                "entity": "realestate\\funding\\FundRequest",
                "transition": "activate",
                "ids": []
            },
            "confirm": true,
            "visible": ["status", "=", "draft"]
        },
        {
            "id": "action.cancel",
            "label": "Cancel",
            "description": "Cancel the fund request. This action is not reversible.",
            "controller": "core_model_transition",
            "visible": [["status", "=", "active"]],
            "params": {
                "entity": "realestate\\funding\\FundRequest",
                "transition": "cancel",
                "ids": []
            },
            "confirm": true
        }
    ],
    "routes": [
        {
            "id": "route.print_pdf",
            "type": "entry",
            "label": "Print Fund Request",
            "icon": "print",
            "description": "",
            "route": "/?get=realestate_funding_FundRequest_render-pdf&id=object.id",
            "target": "_blank",
            "absolute": true,
            "visible_help": "Printing is meant for FundRequestExecution",
            "visible": false
        }
    ],
