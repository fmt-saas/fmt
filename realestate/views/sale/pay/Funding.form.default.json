{
    "name": "Funding",
    "description": "",
    "routes": [
        {
            "id": "route.export_sepa",
            "label": "Export SEPA",
            "description": "Generate a SEPA XML envelope.",
            "icon": "print",
            "route": "/?get=sale_pay_Funding_sepa&id=object.id",
            "target": "_blank",
            "absolute": true,
            "visible": [["pending", "=", "object.status"], ["due_amount", "<", 0], ["has_mandate", "=", false]]
        }
    ],
    "layout": {
        "groups": [
            {
                "sections": [
                    {
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "66%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "name",
                                                "width": "100%",
                                                "widget": {
                                                    "heading": true
                                                },
                                                "visible": ["state", "<>", "draft"]
                                            },
                                            {
                                                "type": "field",
                                                "value": "description",
                                                "width": "100%",
                                                "widget": {
                                                    "heading": true
                                                },
                                                "visible": ["state", "=", "draft"]
                                            },
                                            {
                                                "type": "field",
                                                "value": "condo_id",
                                                "width": "0%",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "value": "status",
                                                "width": "0%",
                                                "visible": false
                                            }
                                        ]
                                    },
                                    {
                                        "width": "33%",
                                        "items": [
                                            {
                                                "type": "label",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Amount Due",
                                                "value": "due_amount",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "is_paid",
                                                "width": "33%",
                                                "visible": false
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            },
            {
                "sections": [
                    {
                        "label": "General Info",
                        "id": "section.funding_section",
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "50%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "free_payment_reference",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "payment_reference",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "funding_type",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "label",
                                                "value": "Document",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Misc Op",
                                                "value": "misc_operation_id",
                                                "width": "50%",
                                                "visible": ["funding_type", "=", "misc_operation"]
