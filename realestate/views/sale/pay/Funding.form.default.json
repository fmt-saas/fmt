                                                "visible": ["funding_type", "=", "statement_line"]
                                            },
                                            {
                                                "type": "field",
                                                "label": "Mandate",
                                                "value": "has_mandate",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Mandate",
                                                "value": "is_sent",
                                                "width": "100%"
