{
    "name": "Data Import",
    "actions": [
        {
            "id": "action.check",
            "label": "Check",
            "description": "Check consistency of uploaded data.",
            "controller": "fmt_import_DataImport_check",
            "params": {
                "id": "object.id"
            },
            "visible": ["status", "=", "pending"]
        },
        {
            "id": "action.import",
            "label": "Import",
            "description": "Import the uploaded data.",
            "controller": "fmt_import_DataImport_import",
            "params": {
                "id": "object.id"
            },
            "visible": ["status", "=", "ready"]
        }
    ],
    "layout": {
        "groups": [
            {
                "sections": [
                    {
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "condo_id",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "name",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "data",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "document_id",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "import_type",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "status",
                                                "width": "100%",
                                                "visible": false
                                            }
                                        ]
                                    }
                                ]
                            },
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "logs",
                                                "width": "100%"
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            }
        ]
    }
}