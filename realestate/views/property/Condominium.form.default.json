{
    "name": "Organisation",
    "description": "Form holding basic information about an Organisation.",
    "routes": [
        {
            "id": "item.role_assignments",
            "label": "Roles Assignments",
            "description": "",
            "icon": "library_books",
            "context": {
                "entity": "hr\\role\\RoleAssignment",
                "view": "list.default",
                "domain": ["condo_id", "=", "object.id"]
            }
        },
        {
            "id": "item.statutory_quotas",
            "label": "Statutory Quotas",
            "description": "",
            "icon": "pie_chart",
            "context": {
                "entity": "realestate\\property\\PropertyLotStatutoryQuota",
                "view": "list.default",
                "domain": ["condo_id", "=", "object.id"]
            }
        },
        {
            "id": "item.apportionment_keys",
            "label": "Apportionment keys",
            "description": "",
            "icon": "account_tree",
            "context": {
                "entity": "realestate\\property\\ApportionmentKey",
                "view": "list.default",
                "domain": ["condo_id", "=", "object.id"]
            }
        }
    ],
