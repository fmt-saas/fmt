            "description": "",
            "context": {
                "entity": "realestate\\property\\Condominium",
                "view": "form.banking",
                "domain": [["id", "=", "object.id"]]
            }
        },
        {
            "id": "suppliers",
            "type": "entry",
            "label": "Suppliers",
            "icon": "storefront",
            "description": "",
            "context": {
                "entity": "purchase\\supplier\\Suppliership",
                "view": "list.default",
                "domain": [["condo_id", "=", "object.id"]]
            }
        },
        {
            "id": "item.governance",
            "label": "Governance",
            "description": "",
            "icon": "how_to_vote",
            "context": {
                "entity": "realestate\\property\\Condominium",
                "view": "form.governance",
                "domain": [["id", "=", "object.id"]]
            }
        },
        {
            "id": "item.admin",
            "label": "Config",
            "description": "",
            "icon": "settings",
            "context": {
                "entity": "realestate\\property\\Condominium",
                "view": "form.admin",
                "domain": [["id", "=", "object.id"]]
            }
        }
