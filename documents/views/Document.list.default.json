{
    "name": "Document list",
    "description": "This view is intended for displaying the list of documents.",
    "header": {
        "actions": {
            "ACTION.CREATE" : false
        }
    },
    "routes": [
        {
            "id": "item.import",
            "label": "Import Document",
            "description": "",
            "icon": "file_upload",
            "context": {
                "entity": "documents\\Document",
                "view": "form.import",
                "purpose": "create",
                "mode": "edit"
            }
        }
    ],
    "layout": {
        "items": [
            {
                "type": "field",
                "label": "Preview",
                "value": "preview_image",
                "width": "10%"
            },
            {
                "type": "field",
                "value": "name",
                "width": "25%",
                "sortable": true
            },
            {
                "type": "field",
                "label": "Created",
                "value": "created",
                "width": "10%",
                "readonly": true,
                "widget": {
                    "usage": "date"
                }
            },
            {
                "type": "field",
                "label": "Type",
                "value": "content_type",
                "width": "10%"
            },
            {
                "type": "field",
                "label": "Language",
                "value": "readable_size",
                "width": "10%"
            },
            {
                "type": "field",
                "value": "link",
                "width": "33%",
                "readonly": true
            },
            {
                "type": "field",
                "value": "tags",
                "label": "Tags",
                "width": "20%",
                "readonly": true
            }
        ]
    }
}