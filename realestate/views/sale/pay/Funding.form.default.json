                                            {
                                                "type": "field",
                                                "value": "bank_account_id",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "counterpart_bank_account_id",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "state",
                                                "width": "0%",
                                                "visible": false
                                            }
                                        ]
                                    },
                                    {
                                        "width": "25%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "label": "Ownership",
                                                "value": "ownership_id",
                                                "width": "100%",
                                                "visible": ["ownership_id", "<>", null]
                                            },
                                            {
                                                "type": "field",
                                                "label": "Suppliership",
                                                "value": "suppliership_id",
                                                "width": "100%",
                                                "visible": ["suppliership_id", "<>", null]
                                            },
                                            {
                                                "type": "field",
                                                "label": "Accounting Account",
                                                "value": "accounting_account_id",
                                                "width": "100%",
                                                "visible": ["accounting_account_id", "<>", null]
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "label": "Payments",
                        "id": "section.payments_section",
                        "visible": ["state", "<>", "draft"],
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "payments_ids",
                                                "width": "100%"
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "label": "Reminders",
                        "id": "section.reminders_section",
                        "visible": ["state", "<>", "draft"],
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "payment_reminders_ids",
                                                "width": "100%"
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            }
        ]
    }
}
