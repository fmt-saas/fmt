{
    "name": "Expense Summary",
    "controller": "finance_accounting_expenseSummary_collect",
    "header": {
        "#memo": "inline layout disables visible actions of the view",
        "layout": "inline",
        "exports": false,
        "actions": false,
        "advanced_search": {
            "open": false
        }
    },
    "actions": [
        {
            "id": "action.export",
            "label": "Export",
            "icon": "list",
            "description": "Export PDF document from filtered data.",
            "controller": "finance_accounting_expenseSummary_export",
            "params": {
            }
        }
    ],
    "group_by": [
        {
            "open": true,
            "colspan": 3,
            "field": "apportionment",
            "operations": {
                "amount": {
                    "operation": "SUM",
                    "usage": "amount/money:2"
                }
            }
        },
        {
            "open": true,
            "colspan": 3,
            "field": "parent_account",
            "operations": {
                "amount": {
                    "operation": "SUM",
                    "usage": "amount/money:2"
                }
            }
        },
        {
            "open": true,
            "colspan": 4,
            "field": "account",
            "operations": {
                "amount": {
                    "operation": "SUM",
                    "usage": "amount/money:2"
                }
            }
        }
    ],
    "layout": {
        "interactions": {
            "click": false
        },
        "items": [
            {
                "type": "field",
                "label": "Condominium",
                "value": "condo_id",
                "width": "25%",
                "visible": false
            },
            {
                "type": "field",
                "value": "apportionment",
                "width": "10%",
                "visible": false
            },
            {
                "type": "field",
                "value": "parent_account",
                "width": "25%",
                "visible": false
            },
            {
                "type": "field",
                "value": "account",
                "width": "25%",
                "visible": false
            },
            {
                "type": "field",
                "value": "description",
                "width": "33%"
            },
            {
                "type": "field",
                "value": "entry_date",
                "width": "10%"
            },
            {
                "type": "field",
                "value": "entry_reference",
                "width": "20%"
            },
            {
                "type": "field",
                "value": "supplier_id",
                "width": "15%"
            },
            {
                "type": "field",
                "value": "supplier_reference",
                "width": "15%"
            },
            {
                "type": "field",
                "value": "owner_share",
                "width": "10%"
            },
            {
                "type": "field",
                "value": "tenant_share",
                "width": "10%"
            },
            {
                "type": "field",
                "value": "vat_rate",
                "width": "10%"
            },
            {
                "type": "field",
                "value": "amount",
                "width": "15%"
            }
        ]
    }
}