{
    "name": "Fiscal Year",
    "header": {
        "actions": {
            "ACTION.SAVE": [
                {
                    "id": "SAVE_AND_CLOSE"
                }
            ]
        }
    },
    "actions": [
        {
            "id": "action.generate_fiscal_periods",
            "label": "Generate fiscal periods",
            "icon": "edit_calendar",
            "description": "Generate fiscal periods according to configuration.",
            "controller": "core_model_do",
            "visible": ["status", "=", "draft"],
            "params": {
                "entity": "finance\\accounting\\FiscalYear",
                "action": "generate_periods",
                "ids": []
            },
            "confirm": true
        },
        {
            "id": "action.generate_sequences",
            "label": "Assert sequences",
            "icon": "edit_calendar",
            "description": "Check and create missing sequences for fiscal Year.",
            "controller": "core_model_do",
            "visible": ["status", "=", "draft"],
            "params": {
                "entity": "finance\\accounting\\FiscalYear",
                "action": "generate_sequences",
                "ids": []
            },
            "confirm": true
        },
        {
            "id": "action.preopen",
            "label": "Pre-open",
            "description": "Pre-open the fiscal year. This will initialize the fiscal year and its dependencies.",
            "controller": "core_model_transition",
            "visible": ["status", "=", "draft"],
            "params": {
                "entity": "finance\\accounting\\FiscalYear",
                "transition": "preopen",
                "ids": []
            },
            "confirm": true
        },
        {
            "id": "action.open",
            "label": "Open",
            "description": "Open the fiscal year (this cannot be undone).",
            "controller": "core_model_transition",
            "visible": ["status", "=", "preopen"],
            "params": {
                "entity": "finance\\accounting\\FiscalYear",
                "transition": "open",
                "ids": []
            },
            "confirm": true
        },
        {
            "id": "action.preclose",
            "label": "Pre-close",
            "description": "Pre-close the fiscal year.",
            "controller": "core_model_transition",
            "visible": false,
            "visible_help": "This status is set automatically.",
            "visible1": ["status", "=", "open"],
            "params": {
                "entity": "finance\\accounting\\FiscalYear",
                "transition": "preclose",
                "ids": []
            },
            "confirm": true
        },
        {
            "id": "action.close",
            "label": "Close",
            "description": "Close the fiscal year.",
            "controller": "core_model_transition",
            "visible1": ["status", "=", "open"],
            "visible": false,
            "visible_help": "#memo - fiscal year closing is handled with ExpenseStatement",
            "params": {
                "entity": "finance\\accounting\\FiscalYear",
                "transition": "close",
                "ids": []
            },
            "confirm": true
        },
        {
            "id": "action.reopen",
            "label": "Reopen",
            "description": "Set fiscal year back to pre-close.",
            "controller": "core_model_transition",
            "visible": ["status", "=", "closed"],
            "params": {
                "entity": "finance\\accounting\\FiscalYear",
                "transition": "repreclose",
                "ids": []
            },
            "confirm": true
        },
        {
            "id": "action.delete",
            "label": "Delete",
            "description": "Delete fiscal year. This can only be done when fiscal year is still a draft.",
            "controller": "core_model_delete",
            "visible": ["status", "=", "draft"],
            "params": {
                "entity": "finance\\accounting\\FiscalYear",
                "ids": []
            },
            "confirm": true
        },
        {
            "id": "action.rebuild_projection",
            "label": "Rebuild projection",
            "description": "Rebuild Account Balance Projection (can take up to a few minutes).",
            "controller": "finance_accounting_FiscalYear_rebuild-balance-projection",
            "visible": [
                [ [["operators"], "in", "user.groups"] ],
                [ [["admins"], "in", "user.groups"] ]
            ],
            "params": {
                "id": "object.id",
                "ids": []
            },
            "confirm": true
        }
    ],
    "layout": {
        "groups": [
            {
                "sections": [
                    {
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "50%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "name",
                                                "width": "100%",
                                                "widget": {
                                                    "heading": true,
                                                    "readonly": true
                                                }
                                            },
                                            {
                                                "type": "field",
                                                "value": "date_from",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "date_to",
                                                "width": "50%"
                                            }

                                        ]
                                    },
                                    {
                                        "width": "50%",
                                        "items": [
                                            {
                                                "id": "item.organisation_id",
                                                "type": "field",
                                                "label": "Organisation",
                                                "value": "organisation_id",
                                                "width": "50%",
                                                "visible": false
                                            },
                                            {
                                                "id": "item.condo_id",
                                                "type": "field",
                                                "label": "Condominium",
                                                "value": "condo_id",
                                                "width": "50%",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "value": "fiscal_period_frequency",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "label",
                                                "value": "",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "opening_balance_id",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "closing_balance_id",
                                                "width": "50%"
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            },
            {
                "sections": [
                    {
                        "id": "section.periods",
                        "label": "Periods",
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "fiscal_periods_ids",
                                                "width": "100%",
                                                "widget": {
                                                    "header": {
                                                        "actions": {
                                                            "ACTION.CREATE": false
                                                        }
                                                    }
                                                }
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            }
        ]
    }
}