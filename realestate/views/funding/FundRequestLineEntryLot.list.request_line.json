{
    "name": "Fund Request Lot Entries",
    "description": "Display the lot-level breakdown of a fund request line.",
    "header": {
        "actions": {
            "ACTION.CREATE": false
        }
    },
    "operations": {
        "total": {
            "allocated_amount": {
                "operation": "SUM",
                "usage": "amount/money:2"
            },
            "apportionment_shares": {
                "operation": "SUM"
            }
        }
    },
    "layout": {
        "items": [
            {
                "type": "field",
                "label": "Ownership",
                "value": "ownership_id",
                "width": "50%",
                "visible": false
            },
            {
                "type": "field",
                "label": "Property lot",
                "value": "property_lot_id",
                "width": "70%"
            },
            {
                "type": "field",
                "label": "Shares",
                "value": "apportionment_shares",
                "width": "15%"
            },
            {
                "type": "field",
                "value": "allocated_amount",
                "width": "15%"
            }
        ]
    }
}
