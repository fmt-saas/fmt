                                                "value": "condo_id",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "fiscal_year_id",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "fiscal_period_id",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "name",
                                                "width": "100%",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "value": "organisation_id",
                                                "width": "100%",
                                                "visible": false
                                            },
                                            {
