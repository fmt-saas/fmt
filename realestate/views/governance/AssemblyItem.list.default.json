{
    "name": "Assembly Resolution",
    "group_by_1": [{
        "open": true,
        "colspan": 3,
        "field": "parent_group_id",
        "order": "name"
    }],
    "order": "order",
    "sort": "asc",
    "draggable": true,
    "limit": 150,
    "domain": [
        ["has_parent_group", "=", false]
    ],
    "routes": [
        {
            "id": "route.show_items",
            "label": "Show items",
            "inline": true,
            "description": "",
            "icon": "visibility",
            "context": {
                "entity": "realestate\\governance\\AssemblyItem",
                "view": "form.popup",
                "mode": "view",
                "purpose": "view",
                "display_mode": "popup",
                "domain": ["id", "=", "object.id"]
            },
            "visible": [
                ["is_group", "=", true],
                ["items_count", ">=", 0],
                ["open", "=", "object.status"],
                ["in_progress", "=", "object.assembly_status"],
                ["agenda_processing", "=", "object.assembly_step"]
            ]
        }
    ],
    "actions": [
        {
            "id": "action.open",
            "inline": true,
            "label": "Open",
            "icon": "play_arrow",
            "description": "Open the point.",
            "controller": "core_model_transition",
            "params": {
                "entity": "realestate\\governance\\AssemblyItem",
                "transition": "open"
            },
            "visible": [
                ["pending", "=", "object.status"],
                ["in_progress", "=", "object.assembly_status"],
                ["agenda_processing", "=", "object.assembly_step"]
            ]
        },
        {
            "id": "action.close",
            "inline": true,
            "label": "Close",
            "icon": "done",
            "description": "Close the assembly resolution. No more vote will be allowed. This cannot be undone.",
            "controller": "realestate_governance_AssemblyItem_close",
            "confirm": true,
            "params": {
                "id": "object.id"
            },
            "visible": [ ["open", "=", "object.status"], [true, "=", "object.has_vote_required"] ]
        },
        {
            "id": "action.close_without_confirmation",
            "inline": true,
            "label": "Close",
            "icon": "done",
            "description": "Close the assembly resolution. No more vote will be allowed. This cannot be undone.",
            "controller": "core_model_transition",
            "confirm": false,
            "params": {
                "entity": "realestate\\governance\\AssemblyItem",
                "transition": "close",
                "ids": []
            },
            "visible": [ ["open", "=", "object.status"], [false, "=", "object.has_vote_required"] ]
        },
        {
            "id": "action.adjourn",
            "inline": true,
            "label": "Adjourn",
            "icon": "event_repeat",
            "description": "Adjourn the assembly resolution. No vote will be allowed. This cannot be undone.",
            "controller": "core_model_transition",
            "confirm": true,
            "params": {
                "entity": "realestate\\governance\\AssemblyItem",
                "transition": "adjourn",
                "ids": []
            },
            "visible": ["open", "=", "object.status"]
        },
        {
            "id": "action.cast_vote",
            "inline": true,
            "label": "Vote",
            "icon": "how_to_vote",
            "description": "Cast a vote.",
            "component": {
                "name": "assemblyVoteCast",
                "data": {
                    "assembly_id": "object.assembly_id",
                    "assembly_item_id": "object.id"
                }
            },
            "visible1": [ [true, "=", "object.has_vote_required"], ["open", "=", "object.status"] ],
            "visible": false,
            "#memo": "we only use votes_board here"
        },
        {
            "id": "action.votes_board",
            "inline": true,
            "label": "Show board",
            "icon": "how_to_vote",
            "description": "Show votes board.",
            "component": {
                "name": "assemblyVoteBoard",
                "data": {
                    "assembly_id": "object.assembly_id",
                    "assembly_item_id": "object.id",
                    "_isFullscreen": true
                }
            },
            "visible": [ [true, "=", "object.has_vote_required"], ["open", "=", "object.status"] ]
        },
        {
            "id": "action.edit_notes",
            "inline": true,
            "label": "Edit minutes",
            "icon": "edit",
            "description": "Edit minutes notes.",
            "component": {
                "name": "assemblyEditItemMinutes",
                "data": {
                    "assembly_id": "object.assembly_id",
                    "assembly_item_id": "object.id"
                }
            },
            "visible": [
                [
                    ["in_progress", "=", "object.assembly_status"],
                    ["agenda_processing", "=", "object.assembly_step"]
                ],
                [
                    ["in_progress", "=", "object.assembly_status"],
                    ["minutes_confirmation", "=", "object.assembly_step"]
                ]
            ]
        }
    ],
    "header": {
        "exports": false,
        "actions": {
            "ACTION.SELECT": true,
            "ACTION.CREATE": true
        }
    },
    "layout": {
        "items": [
            {
                "type": "field",
                "value": "condo_id",
                "width": "0%",
                "visible": false
            },
            {
                "type": "field",
                "value": "assembly_id",
                "width": "0%",
                "visible": false
            },
            {
                "type": "field",
                "value": "assembly_status",
                "width": "0%",
                "visible": false
            },
            {
                "type": "field",
                "value": "assembly_step",
                "width": "0%",
                "visible": false
            },
            {
                "type": "field",
                "value": "order",
                "width": "8%"
            },
            {
                "type": "field",
                "value": "name",
                "width": "30%"
            },
            {
                "type": "field",
                "value": "is_group",
                "width": "10%",
                "visible": false
            },
            {
                "type": "field",
                "value": "has_parent_group",
                "width": "0%",
                "visible": false
            },
            {
                "type": "field",
                "label": "Group",
                "value": "parent_group_id",
                "width": "11%",
                "visible": false
            },
            {
                "type": "field",
                "value": "code",
                "width": "25%",
                "visible": false
            },
            {
                "type": "field",
                "label": "Items",
                "value": "items_count",
                "width": "10%",
                "widget": {
                    "align": "center",
                    "margin": "auto",
                    "styles": {
                        "text_align": "center",
                        "text_width": "40px",
                        "text_weight": "bold",
                        "text_color": "white",
                        "background_color": "#3f51b5",
                        "border_radius": "40px"
                    }
                },
                "visible": [ ["is_group", "=", true], ["items_count", ">=", 0] ]
            },
            {
                "type": "field",
                "label": "Vote",
                "value": "has_vote_required",
                "width": "10%"
            },
            {
                "type": "field",
                "label": "Choices",
                "value": "has_choices",
                "width": "10%",
                "visible": false
            },
            {
                "type": "field",
                "value": "majority",
                "width": "15%"
            },
            {
                "type": "field",
                "value": "vote_result",
                "width": "15%"
            },
            {
                "type": "field",
                "label": "Documents",
                "value": "documents_count",
                "width": "10%",
                "widget": {
                    "align": "center",
                    "margin": "auto",
                    "styles": {
                        "text_align": "center",
                        "text_width": "40px",
                        "text_weight": "bold",
                        "text_color": "white",
                        "background_color": "#3f51b5",
                        "border_radius": "40px"
                    }
                },
                "visible": [ ["documents_count", ">", 0] ]
            },
            {
                "type": "field",
                "value": "status",
                "width": "10%",
                "visible": ["assembly_status", "=", "in_progress"]
            }
        ]
    }
}
