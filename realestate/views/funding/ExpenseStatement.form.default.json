{
    "name": "Expense Statement",
    "description": "An Expense Statement is issued at the end of the fiscal period and allows the co-owners to cover common expenses, as well as to reimburse any private charges they may have.",
    "header": {
        "actions": {
            "ACTION.SAVE": [
                {"id": "SAVE_AND_VIEW"},
                {"id": "SAVE_AND_CONTINUE"},
                {"id": "SAVE_AND_CLOSE"}
            ]
        }
    },
    "actions": [
        {
            "id": "action.generate_statement",
            "label": "Generate statement",
            "description": "Generate the lines of the statement.",
            "controller": "core_model_do",
            "params": {
                "entity": "realestate\\funding\\ExpenseStatement",
                "action": "generate_statement"
            },
            "visible": ["status", "=", "proforma"]
        },
        {
            "id": "action.invoice",
            "label": "Validate",
            "description": "To Invoice.",
            "controller": "core_model_transition",
            "visible": [["state", "=", "instance"], ["status", "=", "proforma"]],
            "params": {
                "entity": "realestate\\funding\\ExpenseStatement",
                "transition": "validate",
                "ids": []
            }
        },
        {
            "id": "action.print_pdf",
            "label": "Download Statement",
            "help": "Current view domain is relayed to called controller.",
            "description": "Generate a document for all owners for current statement.",
            "controller": "realestate_funding_ExpenseStatement_render-pdf",
            "visible_help": "Download relies on related Exporting Task",
            "visible": false
        }
    ],
    "routes": [
        {
            "id": "route.print_pdf",
            "type": "entry",
            "label": "Print Statement",
            "icon": "print",
            "description": "",
            "route": "/?get=realestate_funding_ExpenseStatement_render-pdf&id=object.id",
            "target": "_blank",
            "absolute": true
        }
    ],
    "layout": {
        "groups": [
