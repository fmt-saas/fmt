{
    "name": "Documents",
    "description": "Document analysis form.",
    "header": {
    },
    "routes": [
        {
            "id": "item.meta_data",
            "label": "Meta data",
            "description": "",
            "icon": "data_object",
            "context": {
                "entity": "documents\\Document",
                "view": "form.meta",
                "mode": "view",
                "purpose": "view",
                "domain": [["id", "=", "object.id"]]
            }
        },
        {
            "id": "item.print",
            "label": "View document",
            "icon": "open_in_new",
            "description": "View printable invite.",
            "route": "/?get=documents_document&id=object.id",
            "target": "_blank",
            "absolute": true
        }
    ],
    "layout": {
        "groups": [
            {
                "sections": [
                    {
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "50%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "name",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "label",
                                                "value": "Document Assignment",
                                                "width": "100%",
                                                "widget": {
                                                    "text_decoration": "underline"
                                                }
                                            },
                                            {
                                                "type": "field",
                                                "value": "has_document_json",
                                                "width": "0%",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "value": "document_type_code",
                                                "width": "0%",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "label": "Document Type",
                                                "value": "document_type_id",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Subtype",
                                                "value": "document_subtype_id",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Condominium",
                                                "value": "condo_id",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "label",
                                                "value": "",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Supplier",
                                                "value": "supplier_id",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "label",
                                                "value": "",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Folder",
                                                "value": "parent_node_id",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "label",
                                                "value": "",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "label",
                                                "value": "Document Linking",
                                                "width": "100%",
                                                "widget": {
                                                    "text_decoration": "underline"
                                                }
                                            },
                                            {
                                                "type": "field",
                                                "value": "is_origin",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "is_source",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Invoice",
                                                "value": "invoice_id",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Bank Statement",
                                                "value": "bank_statement_id",
                                                "width": "50%"
                                            }
                                        ]
                                    },
                                    {
                                        "width": "50%",
                                        "visible": ["state", "=", "draft"],
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "data",
                                                "width": "100%"
                                            }
                                        ]
                                    },
                                    {
                                        "width": "50%",
                                        "visible": ["state", "<>", "draft"],
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "link",
                                                "width": "100%",
                                                "visible": ["document_type_code", "in", ["invoice", "credit_note"]],
                                                "widget": {
                                                    "type": "pdf",
                                                    "height": "700"
                                                }
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            }
        ]
    }
}
