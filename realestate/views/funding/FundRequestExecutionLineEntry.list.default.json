{
    "name": "Fund Request Execution Line Entry",
    "description": "A Fund Request Execution Line Entry represents an individual allocation within a Fund Request Execution Line,\r\n        detailing the called amount for a specific property lot, for a given owner and period.",
    "operations": {
        "total": {
            "called_amount": {
                "operation": "SUM",
                "usage": "amount/money:2"
            }
        }
    },
    "layout": {
        "items": [
            {
                "type": "field",
                "value": "condo_id",
                "width": "14%"
            },
            {
                "type": "field",
                "value": "fund_request_id",
                "width": "14%"
            },
            {
                "type": "field",
                "value": "ownership_id",
                "width": "14%"
            },
            {
                "type": "field",
                "value": "property_lot_id",
                "width": "14%"
            },
            {
                "type": "field",
                "value": "called_amount",
                "width": "14%"
            }
        ]
    }
}