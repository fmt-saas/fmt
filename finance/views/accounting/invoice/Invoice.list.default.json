{
    "name": "Invoices",
    "description": "This view is intended for displaying the invoices.",
    "controller": "finance_accounting_invoice_invoice-collect",
    "header": {
        "actions": {
            "ACTION.CREATE": false
        }
    },
    "operations": {
        "total": {
            "total": {
                "operation": "SUM",
                "usage": "amount/money:2"
            },
            "price": {
                "operation": "SUM",
                "usage": "amount/money:2"
            }
        }
    },
    "limit": 100,
    "layout": {
        "items": [
            {
                "id": "item.id",
                "type": "field",
                "value": "id",
                "width": "10%",
                "visible": false
            },
            {
                "id": "item.name",
                "type": "field",
                "value": "name",
                "width": "20%",
                "sortable": true
            },
            {
                "id": "item.emission.date",
                "type": "field",
                "value": "emission_date",
                "width": "20%",
                "sortable": true,
                "widget": {
                    "usage": "date"
                }
            },
            {
                "type": "field",
                "value": "total",
                "width": "15%"
            },
            {
                "type": "field",
                "value": "price",
                "width": "15%"
            },
            {
                "type": "field",
                "value": "status",
                "width": "20%"
            }
        ]
    }
}