                            [
                                "node_type",
                                "=",
                                "folder"
                            ]
                        ],
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "nodes_ids",
                                                "width": "100%",
                                                "widget": {
                                                    "header": {
                                                        "layout": "inline"
                                                    },
                                                    "view": "list.default"
                                                }
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            }
