{
    "name": "Organisation",
    "description": "Form holding basic information about an Organisation.",
    "routes": [
        {
            "id": "item.ownerships",
            "label": "Owners",
            "description": "",
            "icon": "group",
            "context": {
                "entity": "realestate\\ownership\\Ownership",
                "view": "list.default",
                "domain": ["condo_id", "=", "object.id"]
            }
        },
        {
            "id": "item.property_lots",
            "label": "Property Lots",
            "description": "",
            "icon": "apartment",
            "context": {
                "entity": "realestate\\property\\PropertyLot",
                "view": "list.default",
                "domain": ["condo_id", "=", "object.id"]
            }
        },
        {
            "id": "item.role_assignments",
            "label": "Roles Assignments",
            "description": "",
            "icon": "library_books",
            "context": {
                "entity": "hr\\role\\RoleAssignment",
                "view": "list.default",
                "domain": ["condo_id", "=", "object.id"]
            }
        },
        {
            "id": "item.statutory_quotas",
            "label": "Statutory Quotas",
            "description": "",
            "icon": "pie_chart",
            "context": {
                "entity": "realestate\\property\\Apportionment",
                "view": "list.statutory",
                "domain": [["condo_id", "=", "object.id"], ["is_statutory", "=", true]]
            }
        },
        {
            "id": "item.apportionment_keys",
            "label": "Apportionment keys",
            "description": "",
            "icon": "account_tree",
            "context": {
                "entity": "realestate\\property\\Apportionment",
                "view": "list.default",
                "domain": [["condo_id", "=", "object.id"], ["is_statutory", "=", false]]
            }
        }
    ],
    "actions": [
        {
            "id": "action.open_fiscal_year",
            "label": "Open fiscal Year",
            "icon": "event_available",
            "description": "Open the fiscal year. This action cannot be undone.",
            "controller": "core_model_do",
            "params": {
                "entity": "realestate\\property\\Condominium",
                "action": "open_fiscal_year",
                "ids": []
            },
            "confirm": true
        }
    ],
    "layout": {
        "groups": [
            {
                "sections": [
                    {
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "50%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "legal_name",
                                                "width": "100%",
                                                "widget": {
                                                    "header": false
                                                }
                                            }
                                        ]
                                    },
                                    {
                                        "width": "25%",
                                        "items": []
                                    },
                                    {
                                        "width": "25%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "label": "Language",
                                                "value": "lang_id",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "type_id",
                                                "width": "100%",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "value": "type",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "value": "has_parent",
                                                "visible": false
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            },
            {
                "sections": [
                    {
                        "label": "Signalétique",
                        "description": "Signalétique",
                        "id": "section.main_info",
                        "rows": [
                            {

                                "columns": [
                                    {
                                        "width": "33%",
                                        "items": [
                                            {
                                                "id": "label.admin",
                                                "type": "label",
                                                "value": "Infos administratives",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "registration_number",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "cadastral_number",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "has_vat",
                                                "width": "100%",
                                                "label": "Subject to VAT",
                                                "help": "Do the company have a VAT number?"
                                            },
                                            {
                                                "type": "field",
                                                "value": "vat_number",
                                                "width": "100%",
                                                "visible": ["has_vat", "=", true]
                                            }
                                        ]
                                    },
                                    {
                                        "width": "33%",
                                        "items": [
                                            {
                                                "id": "label.construction",
