{
    "name": "Accounting entry line",
    "header": {
        "layout": "inline",
        "actions": {
            "ACTION.CREATE_INLINE":  [
                {
                    "view": false
                }
            ]
        }
    },
    "actions": [
        {
            "id": "action.match",
            "inline": true,
            "label": "Match",
            "icon": "list",
            "description": "Match recording.",
            "component": {
                "name": "matchAccountingEntry",
                "data": {
                    "condo_id": "object.condo_id",
                    "accounting_entry_line_id": "object.id"
                }
            }
        }
    ],
    "operations": {
        "total": {
            "credit": {
                "operation": "SUM",
                "usage": "amount/money:2"
            },
            "debit": {
                "operation": "SUM",
                "usage": "amount/money:2"
            }
        }
    },
    "limit": 100,
    "layout": {
        "items": [
            {
                "type": "field",
                "label": "Condominium",
                "value": "condo_id",
                "width": "25%",
                "visible": false
            },
            {
                "type": "field",
                "label": "Account",
                "value": "account_id",
                "width": "25%",
                "visible": false
            },
            {
                "type": "field",
                "label": "Journal",
                "value": "journal_id",
                "width": "15%"
            },
            {
                "type": "field",
                "label": "Accounting Entry",
                "value": "accounting_entry_id",
                "width": "25%",
                "widget": {
                    "view": "form.default"
                }
            },
            {
                "type": "field",
                "value": "entry_date",
                "width": "15%"
            },
            {
                "type": "field",
                "value": "description",
                "width": "25%"
            },
            {
                "type": "field",
                "value": "debit",
                "width": "15%"
            },
            {
                "type": "field",
                "value": "credit",
                "width": "15%"
            }
        ]
    }
}