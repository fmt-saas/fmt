{
    "name": "Assembly",
    "description": "Edit assembly information, agenda, and logistics.",
    "header": {
        "actions": {
            "ACTION.EDIT1": {"visible": ["status", "=", "pending"]},
            "ACTION.SAVE": [{"id": "SAVE_AND_VIEW"}, {"id": "SAVE_AND_CONTINUE"}, {"id": "SAVE_AND_CLOSE"}]
        }
    },
    "actions": [
        {
            "id": "action.publish",
            "label": "Publish",
            "description": "Publish the assembly (ready for sending).",
            "controller": "core_model_transition",
            "params": {
                "entity": "realestate\\governance\\Assembly",
                "transition": "publish"
            },
            "visible": [
                "status",
                "=",
                "pending"
            ]
        },
        {
            "id": "action.revert_publish",
            "label": "Revert to draft",
            "description": "Revet assembly to draft (to allow edition).",
            "controller": "core_model_transition",
            "params": {
                "entity": "realestate\\governance\\Assembly",
                "transition": "revert_publish"
            },
            "visible": [
                "status",
                "=",
                "published"
            ]
        },
        {
            "id": "action.refresh_owners",
            "label": "Refresh Owners",
            "description": "Refresh Owners list, in case a transfer impacted the list in the meantime.",
            "controller": "core_model_do",
            "params": {
                "entity": "realestate\\governance\\Assembly",
                "action": "generate_ownerships",
                "ids": []
            },
            "confirm": true,
            "visible": false,
            "visible1": [
                "status",
                "=",
                "published"
            ]
        },
        {
            "id": "action.invite",
            "label": "Create Invites",
            "description": "Generate & Send invites. This will generate an export task for downloading an archive with all invites meant to be printed. And it will post emails to the sending queue.",
            "controller": "core_model_transition",
            "confirm": true,
            "params": {
                "entity": "realestate\\governance\\Assembly",
                "transition": "send",
                "ids": []
            },
            "visible": [
                "status",
                "=",
                "published"
            ]
        },
        {
            "id": "action.sent",
            "label": "Mark as Sent",
            "description": "Mark all invitations correspondences as sent. If some emails haven't been sent yet, this action will fail.",
            "controller": "core_model_transition",
            "params": {
                "entity": "realestate\\governance\\Assembly",
                "transition": "sent"
            },
            "visible": [
                "status",
                "=",
                "sending"
            ]
        },
        {
            "id": "action.open",
            "label": "Open Assembly",
            "description": "Open the assembly (mark as in progress).",
            "controller": "core_model_transition",
            "params": {
                "entity": "realestate\\governance\\Assembly",
                "transition": "open"
            },
            "visible": [
                "status",
                "=",
                "sent"
            ]
        },
        {
            "id": "action.validate_all",
            "label": "Validate ",
            "description": "Attempts to validate mandates, attendees and Assembly.",
            "controller": "core_model_do",
            "params": {
                "entity": "realestate\\governance\\Assembly",
                "action": "validate_all"
            },
            "visible": [
                [
                    "is_valid",
                    "=",
                    true
                ],
                [
                    "status",
                    "=",
                    "in_progress"
                ],
                [
                    "step",
                    "in",
                    ["mandate_validation", "representation_validation", "assembly_validation"]
                ]
            ]
        },
        {
            "id": "action.validate_mandates",
            "label": "Validate Mandates",
            "description": "Validate the Attendees' mandates and step to representation validation.",
            "controller": "core_model_do",
            "params": {
                "entity": "realestate\\governance\\Assembly",
                "action": "validate_mandates"
            },
            "visible": false,
            "visible1": [
                [
                    "status",
                    "=",
                    "in_progress"
                ],
                [
                    "step",
                    "=",
                    "mandate_validation"
                ]
            ]
        },
        {
            "id": "action.validate_attendance",
            "label": "Validate Attendance",
            "description": "Step to attendance validation.",
            "controller": "core_model_do",
            "params": {
                "entity": "realestate\\governance\\Assembly",
                "action": "validate_representations"
            },
            "visible": false,
            "visible1": [
                [
                    "status",
                    "=",
                    "in_progress"
                ],
                [
                    "step",
                    "=",
                    "representation_validation"
                ]
            ]
        },
        {
            "id": "action.validate_assembly",
            "label": "Validate Assembly",
            "description": "Attempts to validate the Assembly.",
            "controller": "core_model_do",
            "params": {
                "entity": "realestate\\governance\\Assembly",
                "action": "validate_assembly"
            },
            "visible": false,
            "visible1": [
                [
                    "is_valid",
                    "=",
                    true
                ],
                [
                    "status",
                    "=",
                    "in_progress"
                ],
                [
                    "step",
                    "=",
                    "assembly_validation"
                ]
            ]
        },
        {
            "id": "action.adjourn_assembly",
            "label": "Adjourn Assembly",
            "description": "Close the Assembly, mark it as adjourned.",
            "controller": "core_model_transition",
            "params": {
                "entity": "realestate\\governance\\Assembly",
                "transition": "adjourn"
            },
            "visible": [
                [
                    "is_valid",
                    "=",
                    false
                ],
                [
                    "status",
                    "=",
                    "in_progress"
                ],
                [
                    "step",
                    "=",
                    "assembly_validation"
                ]
            ]
        },
        {
            "id": "action.schedule_second_session",
            "label": "Schedule second session",
            "description": "Schedule a second session for the Assembly.",
            "controller": "core_model_do",
            "params": {
                "entity": "realestate\\governance\\Assembly",
                "action": "schedule_second_session"
            },
            "visible": [
                [
                    "is_valid",
                    "=",
                    false
                ],
                [
                    "status",
                    "=",
                    "adjourned"
                ],
                [
                    "has_second_session",
                    "=",
                    false
                ]
            ]
        },
        {
            "id": "action.add_attendee",
            "label": "Add attendee",
            "description": "Register an attendee, collect its mandates and its signature.",
            "component": {
                "name": "assemblyAddAttendee",
                "data": {
                    "condo_id": "object.condo_id",
                    "assembly_id": "object.id"
                }
            },
            "visible": [
                [
                    "status",
                    "=",
                    "in_progress"
                ],
                [
                    "step",
                    "=",
                    "opening"
                ]
            ]
        },
        {
            "id": "action.add_extra_attendee",
            "label": "Add extra attendee",
            "description": "Register an additional attendee, collect its mandates and its signature.",
            "component": {
                "name": "assemblyAddAttendee",
                "data": {
                    "condo_id": "object.condo_id",
                    "assembly_id": "object.id"
                }
            },
            "visible": [
                [
                    "status",
                    "=",
                    "in_progress"
                ],
                [
                    "step",
                    "=",
                    "agenda_processing"
                ],
                [
                    "count_represented_owners",
                    "<",
                    "object.count_owners"
                ]
            ]
        },
        {
            "id": "action.close_attendance",
            "label": "Close Attendance",
            "description": "Close the attendance part of the session: no more attendance will be registered afterward.",
            "controller": "core_model_do",
            "params": {
                "entity": "realestate\\governance\\Assembly",
                "action": "close_attendance",
                "ids": []
            },
            "confirm": true,
            "visible": [
                [
                    "status",
                    "=",
                    "in_progress"
                ],
                [
                    "step",
                    "=",
                    "opening"
                ]
            ]
        },
        {
            "id": "action.generate_minutes",
            "label": "Generate minutes",
            "description": "Generate the signable version of the minutes of the Assembly.",
            "controller": "core_model_do",
            "params": {
                "entity": "realestate\\governance\\Assembly",
                "action": "generate_signable_minutes"
            },
            "visible": [
                [
                    "status",
                    "=",
                    "in_progress"
                ],
                [
                    "step",
                    "in",
                    [
                        "agenda_processing",
                        "minutes_confirmation"
                    ]
                ]
            ],
            "visible1": [
                "is_complete",
                "=",
                true
            ]
        },
        {
            "id": "action.validate_minutes",
            "label": "Accept minutes",
            "description": "Generate the signable version of the minutes of the Assembly.",
            "controller": "realestate_governance_Assembly_accept-minutes",
            "confirm": true,
            "params": {
                "id": "object.id"
            },
            "visible": [
                [
                    "status",
                    "=",
                    "in_progress"
                ],
                [
                    "step",
                    "in",
                    [
                        "minutes_confirmation"
                    ]
                ]
            ]
        },
        {
            "id": "action.add_signature",
            "label": "Add a signature",
            "description": "Add a signatory to the Assembly Minutes document.",
            "component": {
                "name": "assemblyAddSignatory",
                "data": {
                    "condo_id": "object.condo_id",
                    "assembly_id": "object.id"
                }
            },
            "visible": [
                [
                    "status",
                    "=",
                    "in_progress"
                ],
                [
                    "step",
                    "in",
                    [
                        "minutes_signing"
                    ]
                ]
            ]
        },
        {
            "id": "action.close_minutes_signing",
            "label": "Finish minutes signing",
            "description": "Close the signing of the signable version of the minutes of the Assembly.",
            "controller": "core_model_do",
            "confirm": true,
            "params": {
                "entity": "realestate\\governance\\Assembly",
                "action": "close_minutes_signing",
                "ids": []
            },
            "visible": [
                [
                    "status",
                    "=",
                    "in_progress"
                ],
                [
                    "step",
                    "in",
                    [
                        "minutes_signing"
                    ]
                ]
            ]
        },
        {
            "id": "action.close",
            "label": "Close",
            "description": "Close the assembly (ready for sending).",
            "controller": "core_model_transition",
            "params": {
                "entity": "realestate\\governance\\Assembly",
                "transition": "close"
            },
            "visible": [
                [
                    "status",
                    "=",
                    "in_progress"
                ],
                [
                    "step", "=", "assembly_closing"
                ]
            ]
        }
    ],
    "routes": [
        {
            "id": "route.all_attachments",
            "label": "All attachments",
            "description": "",
            "icon": "attach_file",
            "visible": {
                "edit": false
            },
            "context": {
                "entity": "documents\\Document",
                "view": "list.assembly",
                "domain": [ ["assembly_id", "=", "object.id"] ]
            }
        },
        {
            "id": "route.preview_invite",
            "type": "entry",
            "label": "Preview Invite",
            "icon": "preview",
            "description": "",
            "route": "/?get=realestate_governance_Assembly_invitation_render-pdf&id=object.id",
            "target": "_blank",
            "absolute": true,
            "visible": [
                "status",
                "in",
                [
                    "pending",
                    "published",
                    "sending"
                ]
            ]
        },
        {
            "id": "route.print_attendance_register_full",
            "type": "entry",
            "label": "Empty Attendance register",
            "icon": "print",
            "description": "View printable attendance register.",
            "route": "/?get=realestate_governance_Assembly_attendanceregister_render-pdf&id=object.id&full=true",
            "target": "_blank",
            "absolute": true,
            "visible": [
                [
                    [
                        "status",
                        "=",
                        "in_progress"
                    ],
                    [
                        "step",
                        "=",
                        "opening"
                    ]
                ]
            ]
        },
        {
            "id": "route.view_attendance_register",
            "type": "entry",
            "label": "View Attendance register",
            "icon": "print",
            "description": "View printable attendance register.",
            "route": "/?get=realestate_governance_Assembly_attendanceregister_fetch&id=object.id",
            "target": "_blank",
            "absolute": true,
            "visible": [
                [
                    [
                        "status",
                        "in",
                        [
                            "held",
                            "adjourned"
                        ]
                    ]
                ],
                [
                    [
                        "status",
                        "=",
                        "in_progress"
                    ],
                    [
                        "step",
                        "=",
                        "agenda_processing"
                    ]
                ]
            ]
        },
        {
            "id": "route.preview_minutes",
            "type": "entry",
            "label": "Preview Minutes",
            "icon": "print",
            "description": "Preview of the signable assembly minutes.",
            "route": "/?get=realestate_governance_Assembly_minutes_fetch&id=object.id",
            "target": "_blank",
            "absolute": true,
            "visible": [
                [
                    [
                        "status",
                        "=",
                        "in_progress"
                    ],
                    [
                        "step",
                        "=",
                        "minutes_confirmation"
                    ]
                ]
            ]
        },
        {
            "id": "route.view_minutes",
            "type": "entry",
            "label": "View Minutes",
            "icon": "print",
            "description": "View printable assembly minutes.",
            "route": "/?get=realestate_governance_Assembly_minutes_fetch&id=object.id",
            "target": "_blank",
            "absolute": true,
            "visible": [
                [
                    [
                        "status",
                        "in",
                        [
                            "held"
                        ]
                    ]
                ],
                [
                    [
                        "status",
                        "=",
                        "in_progress"
                    ],
                    [
                        "step",
                        "=",
                        "assembly_closing"
                    ]
                ]
            ]
        }
    ],
    "layout": {
        "groups": [
            {
                "sections": [
                    {
                        "id": "section.details",
                        "label": "Details",
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "50%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "assembly_type",
                                                "width": "33%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "name",
                                                "width": "66%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "assembly_date",
                                                "width": "33%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "session_time_start",
                                                "width": "33%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "session_time_end",
                                                "width": "33%",
                                                "visible": [
                                                    "status",
                                                    "not in",
                                                    [
                                                        "pending",
                                                        "published",
                                                        "sending",
                                                        "sent"
                                                    ]
                                                ]
                                            },
                                            {
                                                "type": "field",
                                                "value": "assembly_location",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Assembly Organizer",
                                                "value": "assembly_organizer_identity_id",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "status",
                                                "width": "100%",
                                                "visible": false
                                            }
                                        ]
                                    },
                                    {
                                        "width": "16%",
                                        "items": []
                                    },
                                    {
                                        "width": "33%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "label": "Condominium",
                                                "value": "condo_id",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Template",
                                                "value": "assembly_template_id",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Minutes",
                                                "value": "minutes_document_id",
                                                "width": "100%",
                                                "visible": [
                                                    "status",
                                                    "not in",
                                                    [
                                                        "pending",
                                                        "published",
                                                        "sending",
                                                        "sent"
                                                    ]
                                                ]
                                            },
                                            {
                                                "type": "field",
                                                "value": "step",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "is_second_session",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "has_second_session",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "second_session_assembly_id",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "related_assembly_id",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "is_valid",
                                                "width": "100%",
                                                "visible": [
                                                    "step",
                                                    "in",
                                                    [
                                                        "assembly_validation",
                                                        "agenda_processing"
                                                    ]
                                                ]
                                            },
                                            {
                                                "type": "field",
                                                "value": "invalidity_reason",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "is_complete",
                                                "width": "100%",
                                                "visible": false
                                            }
                                        ]
                                    }
                                ]
                            },
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "heading_text_call",
                                                "width": "100%",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "value": "closing_text_call",
                                                "width": "100%",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "value": "heading_text_minutes",
                                                "width": "100%",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "value": "closing_text_minutes",
                                                "width": "100%",
                                                "visible": false
                                            },
                                            {
                                                "type": "label",
                                                "value": "options",
                                                "width": "100%",
                                                "widget": {
                                                    "text_decoration": "underline"
                                                }
                                            },
                                            {
                                                "type": "field",
                                                "value": "has_call_option_majority",
                                                "width": "25%"
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "section.resolutions",
                        "label": "Resolutions",
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "assembly_items_ids",
                                                "width": "100%"
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "section.owners",
                        "label": "Owners",
                        "visible": [
                            [ "status", "not in", [ "pending", "published" ] ],
                            ["admins", "in", "user.groups"]
                        ],
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "ownerships_ids",
                                                "width": "100%",
                                                "widget": {
                                                    "view": "list.assembly"
                                                }
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "section.correspondences",
                        "label": "Correspondences",
                        "visible": [
                            "status",
                            "not in",
                            [
                                "pending",
                                "published"
                            ]
                        ],
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "id": "label.exporting_tasks",
                                                "type": "label",
                                                "value": "Export tasks",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "exporting_tasks_ids",
                                                "width": "100%"
                                            },
                                            {
                                                "id": "label.invitation_correspondences",
                                                "type": "label",
                                                "value": "Invitations correspondences",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "assembly_invitation_correspondences_ids",
                                                "width": "100%",
                                                "widget": {
                                                    "view": "list.assembly",
                                                    "domain": ["communication_method", "=", "email"]
                                                }
                                            },
                                            {
                                                "id": "label.minutes_correspondences",
                                                "type": "label",
                                                "value": "Minutes correspondences",
                                                "width": "100%",
                                                "visible": [
                                                    ["step", "=", "assembly_closing"],
                                                    ["status", "in", ["in_progress", "held", "adjourned"]]
                                                ]
                                            },
                                            {
                                                "type": "field",
                                                "value": "assembly_minutes_correspondences_ids",
                                                "width": "100%",
                                                "widget": {
                                                    "view": "list.assembly",
                                                    "domain": ["communication_method", "=", "email"]
                                                },
                                                "visible": [
                                                    ["step", "=", "assembly_closing"],
                                                    ["status", "in", ["in_progress", "held", "adjourned"]]
                                                ]
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "section.proxies",
                        "label": "Mandates",
                        "visible": [
                            "status",
                            "not in",
                            [
                                "pending",
                                "published",
                                "sending",
                                "sent"
                            ]
                        ],
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "assembly_mandates_ids",
                                                "width": "100%"
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "section.attendees",
                        "label": "Attendees",
                        "visible": [
                            "status",
                            "not in",
                            [
                                "pending",
                                "published",
                                "sending",
                                "sent"
                            ]
                        ],
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "count_owners",
                                                "width": "25%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "count_represented_owners",
                                                "width": "25%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "count_shares",
                                                "width": "25%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "count_represented_shares",
                                                "width": "25%"
                                            }
                                        ]
                                    }
                                ]
                            },
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "signed_register_document_id",
                                                "width": "50%",
                                                "visible": [
                                                    "signed_register_document_id",
                                                    "is not",
                                                    null
                                                ]
                                            }
                                        ]
