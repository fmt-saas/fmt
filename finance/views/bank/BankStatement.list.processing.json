{
    "name": "Bank Statements",
    "description": "This view is intended for displaying the list of bank statements.",
    "header": {
        "actions": {
            "ACTION.CREATE": false
        }
    },
    "routes": [
        {
            "id": "item.import",
            "label": "Import a Bank Statement",
            "description": "",
            "icon": "receipt_long",
            "context": {
                "entity": "finance\\bank\\BankStatementImport",
                "view": "form.import",
                "purpose": "create"
            }
        },
        {
            "id": "route.bank_statement",
            "label": "Invoice",
            "inline": true,
            "description": "",
            "icon": "visibility",
            "context": {
                "entity": "finance\\bank\\BankStatement",
                "view": "form.default",
                "domain": ["id", "=", "object.id"]
            }
        }
    ],
    "order": "created",
    "sort": "desc",
    "layout": {
        "items": [
            {
                "type": "field",
                "value": "id",
                "width": "10%",
                "visible": false
            },
            {
                "type": "field",
                "value": "condo_id",
                "width": "30%",
                "visible": false
            },
            {
                "type": "field",
                "label": "name",
                "value": "bank_account_id",
                "width": "30%"
            },
            {
                "type": "field",
                "value": "date",
                "width": "15%"
            },
            {
                "type": "field",
                "label": "Description",
                "value": "name",
                "width": "33%",
                "readonly": true
            },
            {
                "type": "field",
                "label": "Assigned Employee",
                "value": "assigned_employee_id",
                "width": "25%",
                "readonly": true
            },
            {
                "type": "field",
                "label": "Document",
                "value": "document_id",
                "width": "25%",
                "readonly": true
            },
            {
                "type": "field",
                "value": "created",
                "width": "10%",
                "readonly": true,
                "widget": {
                    "usage": "date"
                }
            },
            {
                "type": "field",
                "value": "alert",
                "width": "10%",
                "readonly": true
            },
            {
                "id": "item.status",
                "type": "field",
                "label": "Status",
                "value": "document_process_status",
                "width": "10%",
                "readonly": true,
                "widget": {
                    "styles": [
                        {
                            "apply": {
                                "text_weight": "500",
                                "text_align": "center",
                                "text_padding": "4px",
                                "border_radius": "5px"
                            }
                        },
                        {
                            "visible": ["integrated", "=", "object.document_process_status"],
                            "apply": {
                                "background_color": "#dcfce7"
                            }
                        },
                        {
                            "visible": [["assigned", "completed", "validated"], "contains", "object.document_process_status"],
                            "apply": {
                                "background_color": "#f5e4b5"
                            }
                        },
                        {
                            "visible": [["created", "cancelled"], "contains", "object.document_process_status"],
                            "apply": {
                                "background_color": "#f5b5b5"
                            }
                        }
                    ]
                }
            }
        ]
    }
}