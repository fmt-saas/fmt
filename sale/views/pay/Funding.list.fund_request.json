{
    "name": "Fundings",
    "description": "This view is intended for displaying the list of fundings.",
    "operations": {
        "total": {
            "due_amount": {
                "operation": "SUM",
                "usage": "amount/money:2"
            },
            "paid_amount": {
                "operation": "SUM",
                "usage": "amount/money:2"
            }
        }
    },
    "layout": {
        "items": [
            {
                "type": "field",
                "value": "name",
                "width": "25%"
            },
            {
                "type": "field",
                "value": "issue_date",
                "width": "15%"
            },
            {
                "type": "field",
                "value": "due_date",
                "width": "15%"
            },
            {
                "type": "field",
                "label": "Owner",
                "value": "ownership_id",
                "width": "20%"
            },
            {
                "type": "field",
                "label": "Fund request",
                "value": "fund_request_id",
                "width": "20%"
            },
            {
                "type": "field",
                "value": "payment_reference",
                "width": "20%"
            },
            {
                "type": "field",
                "label": "Paid",
                "value": "is_paid",
                "width": "15%"
            },
            {
                "type": "field",
                "label": "Amount Paid",
                "value": "paid_amount",
                "width": "15%"
            },
            {
                "type": "field",
                "label": "Amount Due",
                "value": "due_amount",
                "width": "15%"
            }
        ]
    }
}