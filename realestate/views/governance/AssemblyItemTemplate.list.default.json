{
    "name": "Assembly Resolution",
    "group_by_1": [{
        "open": true,
        "colspan": 3,
        "field": "parent_group_id",
        "order": "name"
    }],
    "order": "order",
    "sort": "asc",
    "draggable": true,
    "limit": 150,
    "domain": [
        ["has_parent_group", "=", false]
    ],
    "layout": {
        "items": [
            {
                "type": "field",
                "value": "order",
                "width": "8%"
            },
            {
                "type": "field",
                "value": "name",
                "width": "20%"
            },
            {
                "type": "field",
                "label": "Group",
                "value": "is_group",
                "width": "10%",
                "visible": false
            },
            {
                "type": "field",
                "label": "Parent",
                "value": "parent_group_id",
                "width": "11%",
                "visible": false
            },
            {
                "type": "field",
                "value": "code",
                "width": "20%"
            },
            {
                "type": "field",
                "label": "Items",
                "value": "items_count",
                "width": "10%",
                "widget": {
                    "align": "center",
                    "margin": "auto",
                    "styles": {
                        "text_align": "center",
                        "text_width": "40px",
                        "text_weight": "bold",
                        "text_color": "white",
                        "background_color": "#3f51b5",
                        "border_radius": "40px"
                    }
                },
                "visible": [ ["is_group", "=", true], ["items_count", ">=", 0] ]
            },
            {
                "type": "field",
                "value": "has_vote_required",
                "width": "10%"
            },
            {
                "type": "field",
                "value": "majority",
                "width": "15%"
            }
        ]
    }
}
