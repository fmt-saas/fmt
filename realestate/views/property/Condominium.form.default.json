                "entity": "realestate\\property\\PropertyLot",
                "view": "list.default",
                "domain": ["condo_id", "=", "object.id"]
            }
        },
        {
            "id": "item.accounting",
            "label": "Accounting",
            "description": "",
            "icon": "edit_note",
            "context": {
                "entity": "realestate\\property\\Condominium",
                "view": "form.accounting",
                "domain": [["id", "=", "object.id"]]
            }
        },
        {
            "id": "documents",
            "type": "entry",
            "label": "Documents",
            "icon": "folder",
            "description": "",
