{
    "name": "Accounting Charts List",
    "description": "This view is intended for displaying the accounting charts.",
    "group_by_deactivated": ["account_class"],
    "limit": 25,
    "order": "name,level",
    "sort": "asc",
    "domain": ["is_visible", "=", true],
    "header": {
        "actions": {
            "ACTION.CREATE" : {
                "view": false,
                "edit": true
            }
        }
    },
    "layout": {
        "items": [
            {
                "type": "field",
                "value": "code",
                "width": "10%",
                "align": "left",
                "sortable": true
            },
            {
                "type": "field",
                "value": "description",
                "width": "25%",
                "sortable": true
            },
            {
                "type": "field",
                "value": "level",
                "width": "0%",
                "visible": false
            },
            {
                "type": "field",
                "label": "Control",
                "value": "is_control_account",
                "width": "10%"
            },
            {
                "type": "field",
                "label": "Class",
                "value": "account_class",
                "width": "10%",
                "sortable": true
            },
            {
                "type": "field",
                "label": "Type",
                "value": "account_type",
                "width": "10%",
                "sortable": true
            },
            {
                "type": "field",
                "label": "Nature",
                "value": "account_nature",
                "width": "10%",
                "sortable": true
            },
            {
                "type": "field",
                "label": "Apportionment",
                "value": "apportionment_id",
                "width": "15%"
            },
            {
                "type": "field",
                "label": "Tenant",
                "value": "tenant_share",
                "width": "10%"
            },
            {
                "type": "field",
                "label": "Owner",
                "value": "owner_share",
                "width": "10%"
            },
            {
                "type": "field",
                "label": "Visible",
                "value": "is_visible",
                "width": "10%"
            }
        ]
    }
}