{
    "name": "Bank Statement Lines",
    "description": "This view is intended for displaying the list of bank statement lines.",
    "header": {
        "layout": "inline",
        "actions": {
            "ACTION.CREATE_INLINE": [
                {
                    "view": true
                }
            ]
        }
    },
    "actions": [
        {
            "id": "action.reconcile",
            "inline": true,
            "label": "Reconcile",
            "icon": "list",
            "description": "Reconcile line.",
            "visible": false,
            "visible1": ["status", "<>", "posted"],
            "visible_help": "This is not longer allowed : matching is fully automated and depends on the selected account.",
            "component": {
                "name": "matchBankStatementLine",
                "data": {
                    "condo_id": "object.condo_id",
                    "bank_statement_line_id": "object.id"
                }
            }
        }
    ],
    "operations": {
        "total": {
            "amount": {
                "operation": "SUM",
                "usage": "amount/money:2"
            }
        }
    },
    "layout": {
        "items": [
            {
                "type": "field",
                "value": "condo_id",
                "width": "10%",
                "visible": false
            },
            {
                "type": "field",
                "value": "bank_statement_id",
                "width": "10%",
                "visible": false
            },
            {
                "type": "field",
                "label": "sequence",
                "value": "sequence_number",
                "width": "10%"
            },
            {
                "type": "field",
                "value": "date",
                "width": "15%"
            },
            {
                "type": "field",
                "label": "Account",
                "value": "accounting_account_id",
                "width": "35%",
                "widget": {
                    "controller": "finance_accounting_Account_collect"
                }
            },
            {
                "type": "field",
                "value": "accounting_account_code",
                "width": "10%",
                "visible": false
            },
            {
                "type": "field",
                "value": "communication",
                "width": "30%"
            },
            {
                "type": "field",
                "value": "amount",
                "width": "10%"
            }
        ]
    }
}