{
    "name": "Accounting Entry",
    "description": "Accounting Entries.",
    "header": {
        "actions": {
            "ACTION.EDIT": false
        }
    },
    "actions": [
        {
            "id": "action.validate",
            "label": "Validate",
            "description": "Validate the accounting entry. This action is not reversible.",
            "controller": "core_model_transition",
            "visible": ["status", "=", "pending"],
            "params": {
                "entity": "finance\\accounting\\AccountingEntry",
                "transition": "validate",
                "ids": []
            },
            "confirm": true
        },
        {
            "id": "action.cancel",
            "label": "Cancel",
            "controller": "core_model_do",
            "visible": false,
            "description": "#memo - Accounting Entry can only be cancelled through its origin accounting document.",
            "params": {
                "entity": "finance\\accounting\\AccountingEntry",
                "action": "cancel",
                "ids": []
            },
            "confirm": true
        }
    ],
    "layout": {
        "groups": [
            {
                "sections": [
                    {
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "50%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "label": "Code",
                                                "value": "entry_number",
                                                "width": "33%",
                                                "visible": ["status", "in", ["validated", "reversed"]],
                                                "readonly": true
                                            },
                                            {
                                                "type": "field",
                                                "label": "Status",
                                                "value": "status",
                                                "width": "33%",
                                                "visible": ["status", "not in", ["validated", "reversed"]],
                                                "readonly": true
                                            },
                                            {
                                                "type": "field",
                                                "label": "Fiscal year",
                                                "value": "fiscal_year_id",
                                                "width": "33%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "entry_date",
                                                "width": "33%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "condominium",
                                                "value": "condo_id",
                                                "width": "33%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "journal",
                                                "value": "journal_id",
                                                "width": "33%"
                                            }
                                        ]
                                    },
                                    {
                                        "width": "50%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "description",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "is_balanced",
                                                "width": "50%",
                                                "visible": ["status", "not in", ["validated", "reversed"]]
                                            },
                                            {
                                                "type": "label",
                                                "value": "",
                                                "width": "50%",
                                                "visible": ["status", "=", "validated"]
                                            },
                                            {
                                                "type": "field",
                                                "label": "Reversed accounting entry",
                                                "value": "reversed_entry_id",
                                                "width": "50%",
                                                "visible": ["status", "=", "reversed"]
                                            },
                                            {
                                                "type": "field",
                                                "label": "Purchase Invoice",
                                                "value": "purchase_invoice_id",
                                                "width": "50%",
                                                "visible": [
                                                    [ ["origin_object_class", "=", "realestate\\purchase\\accounting\\invoice\\PurchaseInvoice"] ],
                                                    [ ["origin_object_class", "=", "purchase\\accounting\\invoice\\PurchaseInvoice"] ]
                                                ]
                                            },
                                            {
                                                "type": "field",
                                                "label": "Fund Request Execution",
                                                "value": "fund_request_execution_id",
                                                "width": "50%",
                                                "visible": [
                                                    [ ["origin_object_class", "=", "realestate\\funding\\FundRequestExecution"] ]
                                                ]
                                            },
                                            {
                                                "type": "field",
                                                "label": "Expense Statement",
                                                "value": "expense_statement_id",
                                                "width": "50%",
                                                "visible": [
                                                    [ ["origin_object_class", "=", "realestate\\funding\\ExpenseStatement"] ]
                                                ]
                                            },
                                            {
                                                "type": "field",
                                                "label": "Sale Invoice",
                                                "value": "sale_invoice_id",
                                                "width": "50%",
                                                "visible": [
                                                    [ ["origin_object_class", "=", "sale\\accounting\\invoice\\SaleInvoice"] ]
                                                ]
                                            },
                                            {
                                                "type": "field",
                                                "label": "Misc Operation",
                                                "value": "misc_operation_id",
                                                "width": "50%",
                                                "visible": [
                                                    [ ["origin_object_class", "=", "finance\\accounting\\MiscOperation"] ]
                                                ]
                                            },
                                            {
                                                "type": "field",
                                                "label": "Bank Statement Line",
                                                "value": "bank_statement_line_id",
                                                "width": "50%",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "label": "Bank Statement",
                                                "value": "bank_statement_id",
                                                "width": "50%",
                                                "visible": [
                                                    [ ["origin_object_class", "=", "finance\\bank\\BankStatementLine"] ]
                                                ]
                                            },
                                            {
                                                "type": "field",
                                                "value": "origin_object_class",
                                                "width": "0%",
                                                "visible": false
                                            }
                                        ]
                                    }
                                ]
                            },
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "entry_lines_ids",
                                                "width": "100%"
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            }
        ]
    }
}
