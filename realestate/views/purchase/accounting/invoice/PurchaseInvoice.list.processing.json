{
    "name": "Invoice",
    "description": "An invoice is a legal document issued by a seller to a buyer that relates to a sale, and is part of the accounting system.",
    "header": {
        "actions": {
            "ACTION.CREATE": false
        }
    },
    "routes": [
        {
            "id": "item.import",
            "label": "Import an Invoice",
            "description": "",
            "icon": "receipt_long",
            "context": {
                "entity": "documents\\processing\\DocumentProcess",
                "view": "form.import",
                "purpose": "create"
            }
        },
        {
            "id": "route.purchase_invoice",
            "label": "Invoice",
            "inline": true,
            "description": "",
            "icon": "visibility",
            "context": {
                "entity": "realestate\\purchase\\accounting\\invoice\\PurchaseInvoice",
                "view": "form.default",
                "domain": ["id", "=", "object.id"]
            }
        }
    ],
    "layout": {
        "items": [
            {
                "type": "field",
                "value": "name",
                "width": "15%",
                "sortable": true
            },
            {
                "type": "field",
                "value": "condo_id",
                "width": "20%"
            },
            {
                "type": "field",
                "value": "suppliership_id",
                "width": "20%"
            },
            {
                "type": "field",
                "value": "emission_date",
                "width": "15%",
                "sortable": true,
                "widget": {
                    "usage": "date/short"
                }
            },
            {
                "type": "field",
                "value": "supplier_invoice_number",
                "width": "15%"
            },
            {
                "type": "field",
                "value": "description",
                "width": "33%",
                "readonly": true
            },
            {
                "type": "field",
                "value": "payable_amount",
                "width": "15%"
            },
            {
                "type": "field",
                "label": "Assigned Employee",
                "value": "assigned_employee_id",
                "width": "25%",
                "readonly": true
            },
            {
                "type": "field",
                "label": "Document",
                "value": "document_id",
                "width": "25%",
                "readonly": true
            },
            {
                "type": "field",
                "value": "created",
                "width": "10%",
                "readonly": true,
                "sortable": true,
                "widget": {
                    "usage": "date"
                }
            },
            {
                "type": "field",
                "value": "alert",
                "width": "10%",
                "readonly": true
            },
            {
                "type": "field",
                "label": "status",
                "value": "document_process_status",
                "width": "10%",
                "readonly": true,
                "widget": {
                    "styles": [
                        {
                            "apply": {
                                "text_weight": "500",
                                "text_align": "center",
                                "text_padding": "4px",
                                "border_radius": "5px"
                            }
                        },
                        {
                            "visible": ["integrated", "=", "object.document_process_status"],
                            "apply": {
                                "background_color": "#dcfce7"
                            }
                        },
                        {
                            "visible": [["assigned", "completed", "validated"], "contains", "object.document_process_status"],
                            "apply": {
                                "background_color": "#f5e4b5"
                            }
                        },
                        {
                            "visible": [["created", "cancelled"], "contains", "object.document_process_status"],
                            "apply": {
                                "background_color": "#f5b5b5"
                            }
                        }
                    ]
                }
            }
        ]
    }
}