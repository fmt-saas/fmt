{
    "name": "Employees",
    "description": "List of all employees.",
    "access": {
        "groups": ["hr.default.users"]
    },
    "header": {
        "selection": {
            "actions" : [
                {
                    "id": "action.create_account",
                    "label": "Create a User account",
                    "icon": "play_arrow",
                    "controller": "hr_employee_Employee_create-user"
                }
            ]
        },
        "actions": {
            "ACTION.CREATE" : [
                {
                    "view": "form.create",
                    "description": "Simplified form to ease creation."
                }
            ]
        }
    },
    "layout": {
        "items": [
            {
                "type": "field",
                "value": "id",
                "width": "10%",
                "visible": false
            },
            {
                "type": "field",
                "value": "name",
                "label": "Name",
                "width": "15%",
                "sortable": true
            },
            {
                "type": "field",
                "value": "code",
                "width": "10%",
                "sortable": true
            },
            {
                "type": "field",
                "label": "Role",
                "value": "role_id",
                "width": "15%",
                "sortable": true
            },
            {
                "type": "field",
                "label": "Identity",
                "value": "identity_id",
                "width": "20%",
                "sortable": true
            },
            {
                "type": "field",
                "label": "Active",
                "value": "is_active",
                "width": "10%",
                "sortable": true
            },
            {
                "type": "field",
                "value": "email",
                "width": "15%",
                "sortable": true
            },
            {
                "type": "field",
                "value": "mobile",
                "width": "15%",
                "sortable": true
            }
        ]
    }
}