{
    "name": "Accounting Charts List",
    "description": "This view is intended for displaying the accounting charts.",
    "group_by_deactivated": ["account_class"],
    "limit": 25,
    "order": "name,level",
    "sort": "asc",
    "domain": ["is_visible", "=", true],
    "layout": {
        "items": [
            {
                "type": "field",
                "value": "code",
                "width": "10%",
                "align": "left"
            },
            {
                "type": "field",
                "value": "description",
                "width": "25%"
            },
            {
                "type": "field",
                "value": "level",
                "width": "0%",
                "visible": false
            },
            {
                "type": "field",
                "label": "Control",
                "value": "is_control_account",
                "width": "10%"
            },
            {
                "type": "field",
                "label": "Class",
                "value": "account_class",
                "width": "20%"
            },
            {
                "type": "field",
                "label": "Type",
                "value": "account_type",
                "width": "10%"
            },
            {
                "type": "field",
                "label": "Nature",
                "value": "account_nature",
                "width": "10%"
            },
            {
                "type": "field",
                "value": "apportionment_id",
                "width": "15%"
            },
            {
                "type": "field",
                "label": "Tenant",
                "value": "tenant_share",
                "width": "10%"
            },
            {
                "type": "field",
                "label": "Owner",
                "value": "owner_share",
                "width": "10%"
            },
            {
                "type": "field",
                "label": "Visible",
                "value": "is_visible",
                "width": "10%"
            }
        ]
    }
}