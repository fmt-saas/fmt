{
    "name": "Bank Statement Line",
    "description": "",
    "actions": [
        {
            "id": "action.attempt_reconcile",
            "label": "Attempt Reconcile",
            "icon": "play_arrow",
            "description": "Attempts to reconcile the line based on given data.",
            "controller": "finance_bank_BankStatementLine_attempt-reconcile",
            "params": {
                "id": "object.id",
                "condo_id": "object.condo_id",
                "accounting_account_id": "object.accounting_account_id"
            },
            "confirm": true,
            "visible": [
                [
                    ["status", "=", "pending"],
                    ["is_reconciled", "=", false]
                ]
            ]
        },
        {
            "id": "action.validate",
            "label": "Validate",
            "description": "Validate the statement line.",
            "controller": "core_model_transition",
            "visible": [
                ["status", "=", "pending"]
            ],
            "params": {
                "entity": "finance\\bank\\BankStatementLine",
                "transition": "post",
                "ids": []
            },
            "confirm": true
        }
    ],
