{
    "name": "Navigation Nodes",
    "description": "Browse nodes displayed in navigation menus and trees.",
    "actions": [
        {
            "id": "action.download",
            "inline": true,
            "label": "Download",
            "icon": "download",
            "description": "Download the document.",
            "controller": "documents_navigation_Node_download",
            "visible": [
                "node_type",
                "=",
                "document"
            ]
        }
    ],
    "order": "node_type,name",
    "sort": "desc,asc",
    "layout": {
        "items": [
            {
                "type": "field",
                "value": "condo_id",
                "width": "0%",
                "visible": false
            },
            {
                "type": "field",
                "value": "parent_id",
                "width": "0%",
                "visible": false
            },
            {
                "type": "field",
                "label": "type",
                "value": "node_type",
                "width": "10%",
                "widget": {
                    "type": "string",
                    "usage": "icon"
                }
            },
            {
                "type": "field",
                "value": "name",
                "width": "14%"
            },
            {
                "type": "field",
                "value": "created",
                "width": "10%",
                "widget": {
                    "usage": "datetime/plain.short"
                },
                "visible": [
                    "node_type",
                    "=",
                    "document"
                ]
            },
            {
                "type": "field",
                "label": "Items",
                "value": "nodes_count",
                "width": "10%",
                "widget": {
                    "align": "center"
                },
                "visible": [
                    "node_type",
                    "=",
                    "folder"
                ]
            },
            {
                "type": "field",
                "value": "code",
                "width": "0%",
                "visible": false
            },
            {
                "type": "field",
                "value": "description",
                "width": "20%",
                "visible": false
            },
            {
                "type": "field",
                "value": "ownership_id",
                "width": "20%"
            },
            {
                "type": "field",
                "value": "supplier_id",
                "width": "20%"
            },
            {
                "type": "field",
                "label": "View",
                "value": "document_link",
                "width": "14%",
                "widget": {
                    "link": "icon"
                }
            }
        ]
    }
}
