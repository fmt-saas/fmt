{
    "name": "Documents",
    "description": "Document analysis form.",
    "header": {
    },
    "actions": [
        {
            "id": "action.start_processing",
            "label": "Start processing",
            "icon": "play_arrow",
            "description": "Initiate the processing of the document.",
            "controller": "core_model_do",
            "visible": ["document_process_id", "=", null],
            "params": {
                "entity": "documents\\Document",
                "action": "start_processing",
                "ids": []
            },
            "confirm": false
        }
    ],
    "routes": [
        {
            "id": "item.meta_data",
            "label": "Meta data",
            "description": "",
            "icon": "data_object",
            "visible": false,
            "context": {
                "entity": "documents\\Document",
                "view": "form.meta",
                "mode": "view",
                "purpose": "view",
                "domain": [["id", "=", "object.id"]]
            }
        },
        {
            "id": "item.print",
            "label": "View document",
            "icon": "open_in_new",
            "description": "View printable invite.",
            "route": "/?get=documents_document&id=object.id",
            "target": "_blank",
            "absolute": true
        }
    ],
    "layout": {
        "groups": [
            {
                "sections": [
                    {
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "50%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "has_document_json",
                                                "width": "0%",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "value": "document_type_code",
                                                "width": "0%",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "value": "name",
                                                "width": "100%"
                                            },
                                            {
                                                "type": "label",
                                                "value": "Document Assignment",
                                                "width": "100%",
                                                "widget": {
                                                    "text_decoration": "underline"
                                                }
                                            },
                                            {
                                                "type": "field",
                                                "label": "Document Type",
                                                "value": "document_type_id",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Subtype",
                                                "value": "document_subtype_id",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Condominium",
                                                "value": "condo_id",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "label",
                                                "value": "",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Supplier",
                                                "value": "supplier_id",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "label",
                                                "value": "",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "label": "Folder",
                                                "value": "parent_node_id",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "label",
                                                "value": "Document Linking",
                                                "width": "100%",
                                                "widget": {
                                                    "text_decoration": "underline"
                                                }
                                            },
                                            {
                                                "type": "field",
                                                "value": "is_origin",
                                                "width": "50%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "is_source",
                                                "width": "50%"
                                            }
                                        ]
                                    },
                                    {
                                        "width": "50%",
                                        "visible": ["state", "=", "draft"],
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "data",
                                                "width": "100%"
                                            }
                                        ]
                                    },
                                    {
                                        "width": "50%",
                                        "visible": ["state", "<>", "draft"],
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "link",
                                                "width": "100%",
                                                "visible": ["document_type_code", "in", ["invoice", "credit_note"]],
                                                "widget": {
                                                    "type": "pdf",
                                                    "height": "700"
                                                }
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            },
            {
                "sections": [
                    {
                        "id": "section.details",
                        "label":"Details",
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "50%",
                                        "align": "left",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "content_type",
                                                "width": "30%",
                                                "readonly": true
                                            },
                                            {
                                                "type": "field",
                                                "value": "readable_size",
                                                "width": "25%",
                                                "readonly": true
                                            },
                                            {
                                                "type": "field",
                                                "label": "Language",
                                                "value": "lang_id",
                                                "width": "33%"
                                            },
                                            {
                                                "type": "field",
                                                "value": "public",
                                                "width": "50%"
                                            }
                                        ]
                                    },
                                    {
                                        "width": "50%",
                                        "align": "right",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "preview_image",
                                                "width": "100%",
                                                "readonly": true
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "section.json",
                        "label":"Document JSON",
                        "visible": ["has_document_json", "=", true],
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "align": "left",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "has_document_json",
                                                "width": "0%",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "value": "document_json",
                                                "width": "50%",
                                                "readonly": true,
                                                "widget": {
                                                    "height": "400"
                                                }
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    },
                    {
                        "id": "sections.analysis",
                        "label": "Document analysis",
                        "visible": ["has_analysis_json", "=", true],
                        "rows": [
                            {
                                "columns": [
                                    {
                                        "width": "100%",
                                        "items": [
                                            {
                                                "type": "field",
                                                "value": "has_analysis_json",
                                                "width": "0%",
                                                "visible": false
                                            },
                                            {
                                                "type": "field",
                                                "value": "analysis_json",
                                                "width": "50%",
                                                "widget": {
                                                    "height": 400
                                                }
                                            }
                                        ]
                                    }
                                ]
                            }
                        ]
                    }
                ]
            }
        ]
    }
}
