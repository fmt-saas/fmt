{
    "name": "Fundings",
    "description": "This view is intended for displaying the list of fundings.",
    "controller": "sale_pay_funding-collect",
    "header": {
        "actions": false,
        "exports": false,
        "selection": {
            "default" : false,
            "actions" : [
                {
                    "id": "header.selection.actions.export",
                    "label": "Export SEPA",
                    "icon": "file_download",
                    "controller": "realestate_sale_pay_Funding_bulk-export"
                }
            ]
        }
    },
    "layout": {
        "items": [
            {
                "type": "field",
                "value": "condo_id",
                "width": "25%"
            },
            {
                "type": "field",
                "value": "name",
                "width": "30%"
            },
            {
                "type": "field",
                "value": "bank_account_id",
                "width": "20%"
            },
            {
                "type": "field",
                "value": "ownership_id",
                "width": "15%"
            },
            {
                "type": "field",
                "value": "suppliership_id",
                "width": "15%"
            },
            {
                "type": "field",
                "value": "due_date",
                "width": "15%"
            },
            {
                "type": "field",
                "label": "Type",
                "value": "funding_type",
                "width": "15%"
            },
            {
                "type": "field",
                "value": "payment_reference",
                "width": "20%"
            },
            {
                "type": "field",
                "label": "Assigned to",
                "value": "assigned_employee_id",
                "width": "20%"
            },
            {
                "type": "field",
                "label": "Amount Due",
                "value": "due_amount",
                "width": "10%"
            },
            {
                "type": "field",
                "label": "Amount Remaining",
                "value": "remaining_amount",
                "width": "10%"
            },
            {
                "type": "field",
                "label": "Mandate",
                "value": "has_mandate",
                "width": "10%"
            },
            {
                "type": "field",
                "label": "Sent",
                "value": "is_sent",
                "width": "10%"
            },
            {
                "type": "field",
                "label": "Paid",
                "value": "status",
                "width": "15%"
            }
        ]
    }
}