{
    "name": "Document list",
    "description": "This view is intended for displaying the list of documents.",
    "header": {
        "actions": {
            "ACTION.CREATE" : false
        }
    },
    "layout": {
        "interactions": {
            "click": false
        },
        "items": [
            {
                "type": "field",
                "label": "Preview",
                "value": "preview_image",
                "width": "10%"
            },
            {
                "type": "field",
                "value": "name",
                "width": "25%",
                "sortable": true
            },
            {
                "type": "field",
                "label": "Created",
                "value": "created",
                "width": "10%",
                "readonly": true,
                "widget": {
                    "usage": "date"
                }
            },
            {
                "type": "field",
                "label": "Type",
                "value": "content_type",
                "width": "10%",
                "visible": false
            },
            {
                "type": "field",
                "label": "Size",
                "value": "readable_size",
                "width": "10%",
                "widget": {
                    "align": "right"
                }
            },
            {
                "type": "field",
                "value": "assembly_item_id",
                "label": "Assembly item",
                "width": "20%",
                "readonly": true
            },
            {
                "type": "field",
                "value": "link",
                "width": "10%",
                "readonly": true,
                "widget": {
                    "icon": "visibility",
                    "link": "icon"
                }
            }
        ]
    }
}